<Window x:Class="MultiQuest_Management.ProgressWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="기기 탐색 중" Height="150" Width="320"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize" WindowStyle="ToolWindow" ShowInTaskbar="True">
    <Grid>
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock x:Name="StatusText" Text="와이파이상에서 Meta Quest 기기 탐색 중..." TextAlignment="Center" Margin="10"/>
            <ProgressBar x:Name="LoadingBar" Height="25" Margin="10" Minimum="0" Maximum="100" Value="0"/>
        </StackPanel>
    </Grid>
</Window>
