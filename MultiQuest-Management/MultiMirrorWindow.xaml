<Window x:Class="MultiQuest_Management.MultiMirrorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MultiMirrorWindow"
        Width="1050" Height="700"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen"
        SizeChanged="OnWindowSizeChanged"
        MinWidth="900" MinHeight="600">
    <Grid Margin="5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" LastChildFill="False">
            <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" HorizontalAlignment="Right">
                <Button Content="Refresh All" HorizontalAlignment="Center" VerticalAlignment="Center" Click="RefreshAll_Click" Margin="5"/>
                <Button Content="Stop All" HorizontalAlignment="Center" VerticalAlignment="Center" Click="StopAll_Click" Margin="5"/>
            </StackPanel>
        </DockPanel>

        <Grid Name="MirrorGrid" Grid.Row="1" Margin="0
              ">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 각 셀에 버튼과 미러링 영역 추가 -->
            <Border Grid.Row="0" Grid.Column="0" Margin="5
                    " BorderBrush="Gray" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="1*"/>
                        <RowDefinition Height="5*"/>
                    </Grid.RowDefinitions>
                    <Label x:Name="Name_Label_0_0" Content="Device Name" FontWeight="Bold" HorizontalAlignment="Left" Width="140" Height="25" VerticalAlignment="Center"/>
                    <Button Content="Refresh" Click="RefreshButton_Click" Tag="0,0" Height="20" HorizontalAlignment="Right" Width="45"/>
                    <Border x:Name="Mirror_Border_0_0" Grid.Row="1" Background="Black"/>
                    <Label x:Name="BatteryState" Content="100%" FontWeight="Bold" Margin="0,0,45,0" HorizontalAlignment="Right" Width="42" Height="25" VerticalAlignment="Center"/>
                    <Image x:Name="Wifi_Image" Margin="0,6,88,7" Source="Images/Wifi.png" Stretch="UniformToFill" HorizontalAlignment="Right" Width="15" Height="11.5" VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <Border Grid.Row="0" Grid.Column="1" Margin="5" BorderBrush="Gray" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="1*"/>
                        <RowDefinition Height="5*"/>
                    </Grid.RowDefinitions>
                    <Label x:Name="Name_Label_0_1" Content="Device Name" FontWeight="Bold" HorizontalAlignment="Left" Width="153" Height="25" VerticalAlignment="Center"/>
                    <Button Content="Refresh" Click="RefreshButton_Click" Tag="0,1" Height="20" HorizontalAlignment="Right" Width="45"/>
                    <Border x:Name="Mirror_Border_0_1" Grid.Row="1" Background="Black"/>
