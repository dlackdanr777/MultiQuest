                    <Image x:Name="Wifi_Image1" Margin="0,6,88,7" Source="Images/Wifi.png" Stretch="UniformToFill" HorizontalAlignment="Right" Width="15" Height="11.5" VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- 동일한 방식으로 나머지 셀 정의 -->
            <!-- 예시: Grid.Row="0" Grid.Column="2" -->
