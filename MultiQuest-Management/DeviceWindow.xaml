<Window x:Class="MultiQuest_Management.DeviceWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:MultiQuest_Management"
        Title="Single Mirror - MultiQuest Management"
        Height="700" Width="1200"
        Background="#0E1116"
        UseLayoutRounding="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType">

    <!-- ================== 글로벌 리소스(팔레트/스타일) ================== -->
    <Window.Resources>
        <!-- Palette -->
        <SolidColorBrush x:Key="Bg0" Color="#0E1116"/>
        <SolidColorBrush x:Key="Bg1" Color="#121722"/>
        <SolidColorBrush x:Key="Card" Color="#141A24"/>
        <SolidColorBrush x:Key="Card2" Color="#0F1622"/>
        <SolidColorBrush x:Key="Stroke" Color="#223047"/>
        <SolidColorBrush x:Key="Accent" Color="#5BD5FF"/>
        <SolidColorBrush x:Key="Accent2" Color="#7C5BFF"/>
        <SolidColorBrush x:Key="Ok" Color="#3CE48C"/>
        <SolidColorBrush x:Key="Bad" Color="#FF5963"/>
        <SolidColorBrush x:Key="Text" Color="#D8E2F1"/>
        <SolidColorBrush x:Key="TextDim" Color="#9DB0C9"/>

        <!-- 아이콘 카드 -->
        <Style x:Key="IconCard" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource Card}"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="BorderBrush" Value="{StaticResource Stroke}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#000" BlurRadius="16" ShadowDepth="2" Opacity="0.35"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 슬롯(타일) 카드 -->
        <Style x:Key="TileCard" TargetType="Border">
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Background" Value="{StaticResource Card2}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Stroke}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#000000" BlurRadius="18" ShadowDepth="2" Opacity="0.35"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 미러 표면 -->
        <Style x:Key="MirrorSurface" TargetType="Border">
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="BorderBrush" Value="#253447"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6"/>
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#0D1420" Offset="0"/>
                        <GradientStop Color="#0B1019" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 네온 버튼 -->
        <Style x:Key="NeonButton" TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource Text}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#2A2F3C" Offset="0"/>
                        <GradientStop Color="#1A2230" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="BorderBrush" Value="#2B3B56"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Border x:Name="bg" CornerRadius="14"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"/>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <Border x:Name="neon" CornerRadius="14" Opacity="0" IsHitTestVisible="False">
                                <Border.BorderBrush>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#5BD5FF" Offset="0"/>
                                        <GradientStop Color="#7C5BFF" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.BorderBrush>
                                <Border.BorderThickness>2</Border.BorderThickness>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="neon" Property="Opacity" Value="1"/>
                                <Setter TargetName="bg" Property="BorderBrush" Value="#3E5F8C"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bg" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.99" ScaleY="0.99"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 네온 미니 버튼 -->
        <Style x:Key="NeonMini" BasedOn="{StaticResource NeonButton}" TargetType="Button">
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="MinWidth" Value="60"/>
            <Setter Property="Height" Value="24"/>
        </Style>

        <!-- 헤더 텍스트 -->
        <Style x:Key="HeaderText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource Text}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
    </Window.Resources>

    <!-- ================== 본문 레이아웃 ================== -->
    <DockPanel>
        <!-- (상단 메뉴 제거됨) -->

        <!-- 좌: 단일 미러  /  우: 아이콘+정지 -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <!-- Left: 미러 전체 -->
                <ColumnDefinition Width="268"/>
                <!-- Right: 컨트롤 패널 -->
            </Grid.ColumnDefinitions>

            <!-- ====== Left: Single Mirror ====== -->
            <Grid Grid.Column="0" Margin="10,20,10,24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <!-- 헤더 -->
                    <RowDefinition/>
                    <!-- 미러 영역 -->
                </Grid.RowDefinitions>

                <!-- 헤더(상태/이름/IP + 배터리 + Refresh) -->
                <Grid Grid.Row="0" Margin="10,0,10,8" MinHeight="30" VerticalAlignment="Center"
                      DataContext="{Binding CurrentDevice}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- 왼쪽: 상태점/이름/IP -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Ellipse Width="20" Height="20" Margin="0,0,8,0">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Fill" Value="{StaticResource Bad}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                            <Setter Property="Fill" Value="{StaticResource Ok}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>

                        <TextBlock Text="{Binding Name}" Foreground="{StaticResource Text}" FontWeight="SemiBold"/>
                        <TextBlock Text="•" Foreground="#314B6D" Margin="6,0,6,0"/>
                        <TextBlock Text="{Binding Ip, StringFormat= (IP {0})}"
                                   Foreground="#6482A7" Margin="6,0,0,0"/>
                    </StackPanel>

                    <!-- 오른쪽: 배터리 + Refresh -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <!-- 시리얼 번호 표시 (배터리의 왼쪽) -->
                        <TextBlock Text="SN: "
                                   Foreground="{StaticResource TextDim}"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding Serial}"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource Text}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,10,0"/>

                        <Grid Width="40" Height="40" Margin="0,0,10,0" VerticalAlignment="Center" IsHitTestVisible="False">
                            <Image Source="Images/Battery.png" Width="40" Height="40" Stretch="Fill"/>
                            <TextBlock Text="{Binding BatteryText}"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource Text}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       TextAlignment="Center" Margin="0,0,2,0" FontSize="11"/>
                        </Grid>

                        <Button Content="Refresh"
                                Style="{StaticResource NeonMini}"
                                VerticalAlignment="Center"
                                Click="RefreshTile_Click"
                                CommandParameter="{Binding}"/>
                    </StackPanel>
                </Grid>

                <!-- 미러 호스트: 단일 -->
                <Border x:Name="PART_MirrorHost"
                        Grid.Row="1"
                        Style="{StaticResource MirrorSurface}"/>
            </Grid>

            <!-- ====== Right: 컨트롤 패널 ====== -->
            <Grid Grid.Column="1" Margin="0,20,24,24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <!-- 상단 라벨 -->
                    <RowDefinition Height="Auto"/>
                    <!-- 아이콘 카드 -->
                    <RowDefinition/>
                    <!-- Spacer -->
                    <RowDefinition Height="Auto"/>
                    <!-- All Device Stop -->
                </Grid.RowDefinitions>

                <!-- 상단 설명 텍스트 -->
                <Label x:Name="All_Device_Start_Menu_Text" Content="                  Device Start Menus"
                       Foreground="{StaticResource TextDim}"
                       Background="{x:Null}" BorderBrush="{x:Null}" />

                <!-- 아이콘 카드 -->
                <Border Grid.Row="1" Style="{StaticResource IconCard}" Margin="0,8,0,0"
                        HorizontalAlignment="Right" VerticalAlignment="Top">
                    <Grid x:Name="IconButtonGrid" Width="160" Height="400">
                        <Grid.RowDefinitions>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Row="0" Grid.Column="0" Margin="4" Click="StartAppBtn_Click" Tag="0" Background="#00000000" BorderBrush="#00707070" Foreground="#00000000">
                            <Image Source="Images/FireSafety.png" Stretch="UniformToFill"/>
                        </Button>
                        <Button Grid.Row="0" Grid.Column="1" Margin="4" Click="StartAppBtn_Click" Tag="1" Background="#00000000" BorderBrush="#00707070">
                            <Image Source="Images/SolarSystem.png" Stretch="UniformToFill"/>
                        </Button>
                        <Button Grid.Row="1" Grid.Column="0" Margin="4" Click="StartAppBtn_Click" Tag="2" Background="#00000000" BorderBrush="#00707070" Foreground="#00000000">
                            <Image Source="Images/OceanAdventure.png" Stretch="UniformToFill"/>
                        </Button>
                        <Button Grid.Row="1" Grid.Column="1" Margin="4" Click="StartAppBtn_Click" Tag="3" Background="#00000000" BorderBrush="#00707070" Foreground="#00000000">
                            <Image Source="Images/EnglishTown.png" Stretch="UniformToFill"/>
                        </Button>

                        <Button Grid.Row="2" Grid.Column="0" Margin="4" Click="StartAppBtn_Click" Tag="4" Background="#00000000" BorderBrush="#00707070" Foreground="{StaticResource Text}">
                            <TextBlock TextAlignment="Center" FontWeight="Bold" Width="69"> <Run>Korean</Run><LineBreak/><Run>History</Run></TextBlock>
                        </Button>
                        <Button Grid.Row="2" Grid.Column="1" Margin="4" Click="StartAppBtn_Click" Tag="5" Background="#00000000" BorderBrush="#00707070" Foreground="{StaticResource Text}">
                            <TextBlock Text="Museum" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"/>
                        </Button>
                        <Button Grid.Row="3" Grid.Column="0" Margin="4" Click="StartAppBtn_Click" Tag="6" Background="#00000000" BorderBrush="#00707070" Foreground="{StaticResource Text}">
                            <TextBlock TextAlignment="Center" FontWeight="Bold" Width="69"> <Run>Brain</Run><LineBreak/><Run>Training</Run></TextBlock>
                        </Button>
                        <Button Grid.Row="3" Grid.Column="1" Margin="4" Click="StartAppBtn_Click" Tag="7" Background="#00000000" BorderBrush="#00707070" Foreground="{StaticResource Text}">
                            <TextBlock TextAlignment="Center" FontWeight="Bold" Width="69"> <Run>Korean</Run><LineBreak/><Run>History2</Run></TextBlock>
                        </Button>
                        <Button Grid.Row="4" Grid.Column="0" Margin="4" Click="StartAppBtn_Click" Tag="8" Background="#00000000" BorderBrush="#00707070" Foreground="{StaticResource Text}">
                            <TextBlock TextAlignment="Center" FontWeight="Bold" Width="69"> <Run>오션</Run><LineBreak/><Run>관람 버전</Run></TextBlock>
                        </Button>
                        <Button Grid.Row="4" Grid.Column="1" Margin="4" Click="StartAppBtn_Click" Tag="9" Background="#00000000" BorderBrush="#00707070" Foreground="{StaticResource Text}">
                            <TextBlock TextAlignment="Center" FontWeight="Bold" Width="69"> <Run>우주</Run><LineBreak/><Run>관람 버전</Run></TextBlock>
                        </Button>
                    </Grid>
                </Border>

                <!-- Device Stop -->
                <Button Grid.Row="3"
                        Content="Stop App"
                        Click ="StopAppBtn_Click"
                        HorizontalAlignment="Right"
                        Width="200" Height="50"
                        FontSize="20" FontWeight="Bold"
                        Style="{StaticResource NeonButton}"
                        Foreground="{StaticResource Bad}" />
            </Grid>
        </Grid>
    </DockPanel>
</Window>
