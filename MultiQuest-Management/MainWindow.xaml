<Window x:Class="MultiQuest_Management.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:MultiQuest_Management"
        Title="MultiQuest Management" Height="700" Width="1200"
        Background="#0E1116"
        UseLayoutRounding="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType">

    <!-- ================== 글로벌 리소스(팔레트/스타일) ================== -->
    <Window.Resources>
        <!-- Palette -->
        <SolidColorBrush x:Key="Bg0" Color="#0E1116"/>
        <SolidColorBrush x:Key="Bg1" Color="#121722"/>
        <SolidColorBrush x:Key="Card" Color="#141A24"/>
        <SolidColorBrush x:Key="Card2" Color="#0F1622"/>
        <SolidColorBrush x:Key="Stroke" Color="#223047"/>
        <SolidColorBrush x:Key="Accent" Color="#5BD5FF"/>
        <SolidColorBrush x:Key="Accent2" Color="#7C5BFF"/>
        <SolidColorBrush x:Key="Ok" Color="#3CE48C"/>
        <SolidColorBrush x:Key="Bad" Color="#FF5963"/>
        <SolidColorBrush x:Key="Text" Color="#D8E2F1"/>
        <SolidColorBrush x:Key="TextDim" Color="#9DB0C9"/>

        <!-- 아이콘 카드 -->
        <Style x:Key="IconCard" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource Card}"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="BorderBrush" Value="{StaticResource Stroke}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#000" BlurRadius="16" ShadowDepth="2" Opacity="0.35"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 슬롯(타일) 카드 -->
        <Style x:Key="TileCard" TargetType="Border">
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Background" Value="{StaticResource Card2}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Stroke}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#000000" BlurRadius="18" ShadowDepth="2" Opacity="0.35"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 미러 표면 -->
        <Style x:Key="MirrorSurface" TargetType="Border">
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="BorderBrush" Value="#253447"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6"/>
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#0D1420" Offset="0"/>
                        <GradientStop Color="#0B1019" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 네온 버튼 -->
        <Style x:Key="NeonButton" TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource Text}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#2A2F3C" Offset="0"/>
                        <GradientStop Color="#1A2230" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="BorderBrush" Value="#2B3B56"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Border x:Name="bg" CornerRadius="14"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"/>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <Border x:Name="neon" CornerRadius="14" Opacity="0" IsHitTestVisible="False">
                                <Border.BorderBrush>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#5BD5FF" Offset="0"/>
                                        <GradientStop Color="#7C5BFF" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.BorderBrush>
                                <Border.BorderThickness>2</Border.BorderThickness>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="neon" Property="Opacity" Value="1"/>
                                <Setter TargetName="bg" Property="BorderBrush" Value="#3E5F8C"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bg" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.99" ScaleY="0.99"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 네온 미니 버튼 -->
        <Style x:Key="NeonMini" BasedOn="{StaticResource NeonButton}" TargetType="Button">
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="MinWidth" Value="60"/>
            <Setter Property="Height" Value="24"/>
        </Style>

        <!-- 헤더 텍스트 -->
        <Style x:Key="HeaderText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource Text}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
    </Window.Resources>

    <!-- ================== 본문 레이아웃 ================== -->
    <DockPanel>
        <!-- 상단 메뉴 -->
        <Menu DockPanel.Dock="Top" Background="{StaticResource Card}">
            <MenuItem Header="_설정" Foreground="White">
                <MenuItem Header="이름 설정" Click="OpenSettings_Click"/>
            </MenuItem>
        </Menu>

        <Grid>
            <!-- 오른쪽 상단 아이콘 메뉴 -->
            <Border Style="{StaticResource IconCard}"
                    HorizontalAlignment="Right" VerticalAlignment="Top"
                    Margin="0,20,24,0">
                <Grid x:Name="IconButtonGrid" Width="200" Height="200">
                    <Grid.RowDefinitions>
                        <RowDefinition/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Row="0" Grid.Column="0" Margin="4" Click="AllDeviceStartAppBtn_Click" Tag="0" Background="#00000000" BorderBrush="#00707070" Foreground="#00000000">
                        <Image Source="Images/FireSafety.png" Stretch="UniformToFill"/>
                    </Button>
                    <Button Grid.Row="0" Grid.Column="1" Margin="4" Click="AllDeviceStartAppBtn_Click" Tag="1" Background="#00000000" BorderBrush="#00707070">
                        <Image Source="Images/SolarSystem.png" Stretch="UniformToFill"/>
                    </Button>
                    <Button Grid.Row="1" Grid.Column="0" Margin="4" Click="AllDeviceStartAppBtn_Click" Tag="2" Background="#00000000" BorderBrush="#00707070" Foreground="#00000000">
                        <Image Source="Images/OceanAdventure.png" Stretch="UniformToFill"/>
                    </Button>
                    <Button Grid.Row="1" Grid.Column="1" Margin="4" Click="AllDeviceStartAppBtn_Click" Tag="3" Background="#00000000" BorderBrush="#00707070" Foreground="#00000000">
                        <Image Source="Images/EnglishTown.png" Stretch="UniformToFill"/>
                    </Button>
                </Grid>
            </Border>

            <!-- All Device Stop -->
            <Button Content="All Device Stop" Click ="AllDeviceStopAppBtn_Click"
                    HorizontalAlignment="Right" Margin="0,270,35,0"
                    Width="200" FontSize="20" FontWeight="Bold"
                    Style="{StaticResource NeonButton}" Foreground="{StaticResource Bad}" Height="50" VerticalAlignment="Top"/>

            <!-- ========== 3×3 슬롯: Devices 바인딩 ========== -->
            <ItemsControl x:Name="Tiles" ItemsSource="{Binding Devices}" Margin="10,20,268,24">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Rows="3" Columns="3"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type local:Device}">
                        <Border Style="{StaticResource TileCard}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition/>
                                    <RowDefinition Height="20"/>
                                </Grid.RowDefinitions>

                                <!-- 헤더 -->
                                <Grid Grid.Row="0" Margin="10,0,10,0" MinHeight="30" VerticalAlignment="Center">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- 왼쪽: 상태/이름/아이피 -->
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <Ellipse Width="9" Height="9" Margin="0,0,8,0">
                                            <Ellipse.Style>
                                                <Style TargetType="Ellipse">
                                                    <Setter Property="Fill" Value="{StaticResource Bad}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                                            <Setter Property="Fill" Value="{StaticResource Ok}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Ellipse.Style>
                                        </Ellipse>

                                        <TextBlock Text="{Binding Name}" Foreground="{StaticResource Text}" FontWeight="SemiBold"/>
                                        <TextBlock Text="•" Foreground="#314B6D" Margin="6,0,6,0"/>
                                        <TextBlock Text="{Binding Ip, StringFormat= (IP {0})}"
                                                   Foreground="#6482A7" Margin="6,0,0,0"/>
                                    </StackPanel>

                                    <!-- 오른쪽: 배터리/Refresh/Open/x버튼 -->
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                        <Grid Width="40" Height="40" Margin="0,0,10,0" VerticalAlignment="Center" IsHitTestVisible="False">
                                            <Image Source="Images/Battery.png" Width="40" Height="40" Stretch="Fill"/>
                                            <TextBlock Text="{Binding BatteryText}" FontWeight="Bold"
                       Foreground="{StaticResource Text}" HorizontalAlignment="Center"
                       VerticalAlignment="Center" TextAlignment="Center" Margin="0,0,2,0" FontSize="11"/>
                                        </Grid>

                                        <Button Content="Refresh"
                Style="{StaticResource NeonMini}"
                VerticalAlignment="Center"
                Click="RefreshTile_Click"
                CommandParameter="{Binding}"/>

                                        <Button Content="Open"
                Margin="6,0,0,0"
                Style="{StaticResource NeonMini}"
                VerticalAlignment="Center"
                Click="OpenDeviceBtn_Click"
                CommandParameter="{Binding}"/>

                                        <!-- x버튼을 오른쪽 끝에 추가 -->
                                        <Button Content="✕"
                Width="18" Height="18" Margin="8,0,0,0"
                Padding="0"
                FontSize="12"
                Foreground="{StaticResource Bad}"
                Background="Transparent"
                BorderBrush="Transparent"
                Cursor="Hand"
                ToolTip="디바이스 삭제"
                Click="DeleteDeviceBtn_Click"
                CommandParameter="{Binding}"/>
                                    </StackPanel>
                                </Grid>

                                <!-- ▼ scrcpy 호스트 + 오버레이 Open 버튼 -->
                                <Grid Grid.Row="1">
                                    <Border x:Name="PART_MirrorHost"
                                    Style="{StaticResource MirrorSurface}"/>
                                </Grid>

                                <!-- 푸터(비움) -->
                                <Grid Grid.Row="2" Margin="10,0,10,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                </Grid>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- 하단 좌/가운데 버튼 -->
            <StackPanel Orientation="Horizontal" Margin="0,0,35,93" HorizontalAlignment="Right" Width="200" Height="50" VerticalAlignment="Bottom">
                <Button Content="Add Device" Click="AddDeviceButton_Click" Style="{StaticResource NeonButton}" Width="200" FontSize="20"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,0,35,24" HorizontalAlignment="Right" Width="200" Height="50" VerticalAlignment="Bottom">
                <Button Content="Search Device" Click="MdnsDiscoveryButton_Click" Style="{StaticResource NeonButton}" Width="200" FontSize="20"/>
            </StackPanel>

            <!-- 상단 설명 텍스트 -->
            <Label x:Name="All_Device_Start_Menu_Text" Content="All Device Start Menu"
                   HorizontalAlignment="Right" VerticalAlignment="Top"
                   Margin="0,12,24,0" Foreground="{StaticResource TextDim}"
                   Background="{x:Null}" BorderBrush="{x:Null}"/>
        </Grid>
    </DockPanel>
</Window>
