        private void UpdateDeviceLabels()
        {
            for (int row = 0; row < MaxRows; row++)
            {
                for (int column = 0; column < MaxColumns; column++)
                {
                    Label nameLabel = _cachedLabels[row, column];
                    int deviceIndex = row * MaxColumns + column;

                    if (deviceIndex < _mainWindow.Devices.Count)
                    {
                        var device = _mainWindow.Devices[deviceIndex];
                        if (device != null && device.Status == "Connected")
                        {
                            // 연결된 디바이스의 이름 출력
                            if (nameLabel != null)
                            {
                                nameLabel.Content = device.Name;
                            }
                        }
                        else
                        {
                            // 디바이스가 연결되지 않은 경우
                            if (nameLabel != null)
                            {
                                nameLabel.Content = "Device Not Found";
                            }
                        }
                    }
                    else
                    {
                        // 디바이스가 없는 경우
                        if (nameLabel != null)
                        {
                            nameLabel.Content = "Device Not Found";
                        }
                    }
                }
            }
        }


        private void AddProcess(Process process, Device device)
        {
            if (process == null || device == null)
                return;
            if (_mirroringProcesses.ContainsKey(device.Ip))
            {
                Debug.WriteLine($"이미 등록된 프로세스: {device.Ip}");
                return;

            }

            _mirroringProcesses[device.Ip] = process;
            process.EnableRaisingEvents = true;
            process.Exited += (s, e) =>
            {
                string ip = device.Ip;
                if (_mirroringProcesses.ContainsKey(ip))
                {
                    _mirroringProcesses.Remove(ip);
                    Debug.WriteLine($"프로세스 제거됨: {ip}");
                }
            };
            Debug.WriteLine($"프로세스 추가됨: {device.Ip}");
        }

        private void UpdateBordersVisibility()
        {
            int deviceCount = _mainWindow.Devices.Count;

            for (int row = 0; row < MaxRows; row++)
            {
                for (int column = 0; column < MaxColumns; column++)
                {
                    int index = row * MaxColumns + column;
                    Debug.WriteLine($"Cached for row {row}, column {column}");
                    var outerBorder = _cachedOuterBorders[row, column]; // 캐싱된 outerBorder 사용

                    if (outerBorder != null)
                    {
                        // 디바이스 숫자만큼 활성화, 나머지는 비활성화
                        outerBorder.Visibility = index < deviceCount ? Visibility.Visible : Visibility.Collapsed;
                    }
                    else
                    {
                        Debug.WriteLine($"Cached outer border not found for row {row}, column {column}");
                    }
                }
            }
        }

        private void BatteryCheckTimer_Tick(object sender, EventArgs e)
        {
            if (_cancellationTokenSource.Token.IsCancellationRequested)
                return;

            UpdateBatteryStatus();
        }

        private async void UpdateBatteryStatus()
        {
            if (_mainWindow.Devices == null || _mainWindow.Devices.Count == 0)
                return;

            foreach (var device in _mainWindow.Devices)
            {
                if (device == null || device.Status != "Connected")
                    continue;

                if (_cancellationTokenSource.Token.IsCancellationRequested)
                    return;

                // 디바이스의 위치 가져오기
                if (_devicePositionMap.TryGetValue(device, out var position))
                {
                    var batteryLabel = _cachedBatteryLabels[position.row, position.column];
                    if (batteryLabel != null)
                    {
                        try
                        {
                            if (_cancellationTokenSource.Token.IsCancellationRequested)
                                return;
                            // 비동기적으로 배터리 잔량 가져오기
                            int batteryLevel = await Task.Run(() => _mainWindow.GetBatteryLevel(device.Ip));
                            if (_cancellationTokenSource.Token.IsCancellationRequested)
                                return;
                            // 배터리 잔량 업데이트
                            Dispatcher.Invoke(() =>
                            {
                                Debug.WriteLine($"배터리 상태 업데이트: {device.Name} - {batteryLevel}%");
                                batteryLabel.Content = batteryLevel >= 0
                                    ? $"{batteryLevel}%"
                                    : "Error";
                            });
                        }
                        catch (Exception ex)
                        {
                            Debug.WriteLine($"배터리 상태 업데이트 실패: {ex.Message}");
                            Dispatcher.Invoke(() =>
                            {
                                batteryLabel.Content = "Error";
                            });
                        }
                    }
                }
            }
        }

        private void WifiCheckTimer_Tick(object sender, EventArgs e)
        {
            UpdateWifi();
        }

        private void UpdateWifi()
        {
            if (_mainWindow.Devices == null || _mainWindow.Devices.Count == 0)
                return;

            foreach (var device in _mainWindow.Devices)
            {
                if (_devicePositionMap.TryGetValue(device, out var position))
                {
                    var wifiImage = _cachedWifiImages[position.row, position.column];

                    if (device == null || device.Status != "Connected")
                    {
                        // 디바이스가 연결되지 않았거나 Wi-Fi 이미지가 없는 경우
                        if (wifiImage != null)
                        {
                            wifiImage.Source = _noWifiImage;
                        }
                        continue;
                    }
                    else if (wifiImage != null)
                    {
                        // Wi-Fi 상태에 따라 이미지 업데이트
                        if (device.Status.Contains("Connected"))
                        {
                            wifiImage.Source = _wifiImage;
                        }
                        else
                        {
                            wifiImage.Source = _noWifiImage;
                        }
                    }

                }
            }
        }
    }
