        // IPv4 또는 IPv4:PORT 형태만 허용
        private static bool IsValidIpEndpoint(string value)
        {
            if (string.IsNullOrWhiteSpace(value)) return false;
            var s = value.Trim();
            // ip:port
            var idx = s.LastIndexOf(':');
            if (idx > 0 && idx < s.Length - 1)
            {
                var host = s.Substring(0, idx);
                var portStr = s[(idx + 1)..];
                if (IPAddress.TryParse(host, out var ip) && ip.AddressFamily == AddressFamily.InterNetwork &&
                    int.TryParse(portStr, out var port) && port > 0 && port <= 65535)
                {
                    return true;
                }
            }
            // ip only
            return IPAddress.TryParse(s, out var ipOnly) && ipOnly.AddressFamily == AddressFamily.InterNetwork;
        }

        // adb devices 목록 중 'ip가 아닌 식별자(USB 등)'로 연결된 디바이스 시리얼 목록 가져오기
        private HashSet<string> GetNonIpAdbSerials()
        {
            var serials = new HashSet<string>(StringComparer.OrdinalIgnoreCase);
            try
            {
                string output = RunCmd("adb devices", 3000);
                var lines = output.Split(new[] { '\r', '\n' }, StringSplitOptions.RemoveEmptyEntries);
                foreach (var line in lines)
                {
                    var trimmed = line.Trim();
                    var parts = trimmed.Split(new[] { '\t', ' ' }, StringSplitOptions.RemoveEmptyEntries);
                    if (parts.Length >= 2)
                    {
                        var addr = parts[0];
                        var state = parts[^1];
                        if (!IsValidIpEndpoint(addr) && state.Equals("device", StringComparison.OrdinalIgnoreCase))
                        {
                            serials.Add(addr);
                        }
                    }
                }
            }
            catch { }
            return serials;
        }

