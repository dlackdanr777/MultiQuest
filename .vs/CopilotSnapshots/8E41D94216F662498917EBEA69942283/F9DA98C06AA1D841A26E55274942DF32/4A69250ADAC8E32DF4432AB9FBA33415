        private void InitializeConnectedDevices()
        {
            string adbOutput = RunCmd("adb devices", 3000);
            var lines = adbOutput.Split(new[] { '\r', '\n' }, StringSplitOptions.RemoveEmptyEntries);

            // USB(비-IP)로 연결된 기기의 시리얼 목록을 확보하여 중복 추가 방지
            var nonIpSerials = GetNonIpAdbSerials();

            foreach (var line in lines)
            {
                if (line.TrimEnd().EndsWith("device"))
                {
                    var parts = line.Split(new[] { '\t', ' ' }, StringSplitOptions.RemoveEmptyEntries);
                    if (parts.Length > 0)
                    {
                        string addr = parts[0];
                        if (!IsValidIpEndpoint(addr)) continue; // IP 형식이 아니면 무시
                        if (Devices.Any(d => d.Ip == addr)) continue; // 이미 같은 주소 존재

                        string serial = RunCmdWithRetry($"adb -s {addr} shell getprop ro.serialno", 1000, 5, 300).Trim();
                        if (string.IsNullOrEmpty(serial) || serial.Contains("not found") || serial.StartsWith("adb.exe"))
                            serial = "UnknownSerial";

                        // 같은 시리얼이 이미 있거나, USB(비-IP) 연결 상태면 추가하지 않음
                        if (!string.Equals(serial, "UnknownSerial", StringComparison.OrdinalIgnoreCase) &&
                            (Devices.Any(d => string.Equals(d.Serial, serial, StringComparison.OrdinalIgnoreCase)) ||
                             nonIpSerials.Contains(serial)))
                            continue;

                        AddDevice(new Device
                        {
                            Serial = serial,
                            Ip = addr,
                            Status = "Connected"
                        });
                    }
                }
            }
        }

