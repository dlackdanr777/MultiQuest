        private void StartAppBtn_Click(object sender, RoutedEventArgs e)
        {
            var button = sender as Button;
            var device = button?.DataContext as Device;
            if (!TryGetPkgIndex(sender, out int index)) { this.IsEnabled = true; return; }
            StartApp(device, index);
        }

        // 순차 처리로 변경
        private void AllDeviceStartAppBtn_Click(object sender, RoutedEventArgs e)
        {
            this.IsEnabled = false;
            if (!TryGetPkgIndex(sender, out int index)) { this.IsEnabled = true; return; }
            if (Devices.Count == 0) { ShowMsg("연결된 기기가 없습니다."); this.IsEnabled = true; return; }

            string activity = "com.unity3d.player.UnityPlayerActivity";
            string[] candidates = _pkgNames[index];

            var failed = new List<string>();
            foreach (var device in Devices)
            {
                if (device.Status != "Connected") continue;

                bool launched = false;
                foreach (var pkg in candidates)
                {
                    string result = RunCmdWithRetry($"adb -s {device.Ip} shell am start -n {pkg}/{activity}", 2000);
                    if (!result.Contains("Error", StringComparison.OrdinalIgnoreCase) &&
                        !result.Contains("does not exist", StringComparison.OrdinalIgnoreCase) &&
                        !result.Contains("실패") &&
                        !result.Contains("Timeout", StringComparison.OrdinalIgnoreCase))
                    {
                        launched = true;
                        break;
                    }
                }

                if (!launched)
                    failed.Add(device.Name);
            }

            Dispatcher.Invoke(() =>
            {
                if (failed.Count > 0) ShowMsg($"일부 기기 앱 실행 실패: {failed.Count}개\n{string.Join("\n", failed)}");
                else ShowMsg("전체 기기 앱 실행 성공");
                this.IsEnabled = true;
            });
        }

        public void StopDeviceApp(Device device, Action onCompleted = null)
        {
            if (device == null || device.Status != "Connected") { ShowMsg("기기를 확인하세요."); return; }

            // 모든 콘텐츠의 모든 후보 패키지 강제 종료
            foreach (var candidates in _pkgNames)
                foreach (var pkg in candidates)
                    RunCmd($"adb -s {device.Ip} shell am force-stop {pkg}", 2000);

            onCompleted?.Invoke();
        }

        // 병렬 처리로 변경
        private async void AllDeviceStopAppBtn_Click(object sender, RoutedEventArgs e)
        {
            this.IsEnabled = false;
            if (Devices.Count == 0) { ShowMsg("연결된 기기가 없습니다."); this.IsEnabled = true; return; }

            // 시작 안내 멘트 (UI가 바쁘지 않도록 비동기 처리)
            Dispatcher.BeginInvoke(new Action(() => ShowMsg("전체 기기 앱 종료중...")));

            // 무거운 작업은 백그라운드에서 처리하여 안내 멘트가 즉시 표시되도록 함
            await Task.Run(() =>
            {
                Parallel.ForEach(Devices.Where(d => d.Status == "Connected"), device =>
                {
                    foreach (var candidates in _pkgNames)
                        foreach (var pkg in candidates)
                            RunCmdWithRetry($"adb -s {device.Ip} shell am force-stop {pkg}", 500, 3, 100);
                });
            });

            // 완료 안내
            ShowMsg("전체 기기 앱 종료");
            this.IsEnabled = true;
        }

        // ====================== mDNS ADB TLS 디스커버리 ======================
        public static class AdbMdnsDiscovery
        {
            private static readonly string[] Services = new[]
            {
                "_adb-tls-connect._tcp.local.",
                "_adb_secure_connect._tcp.local."
            };

            public static Task<List<(string ip, int port)>> DiscoverAsync(int mdnsTimeoutMs = 5000)
                => DiscoverAsync(CancellationToken.None, mdnsTimeoutMs);

            public static async Task<List<(string ip, int port)>> DiscoverAsync(CancellationToken token, int mdnsTimeoutMs = 5000)
            {
                var results = new List<(string, int)>();
                var tasks = Services.Select(svc =>
                    ZeroconfResolver.ResolveAsync(svc, scanTime: TimeSpan.FromMilliseconds(mdnsTimeoutMs))).ToArray();
                var all = await Task.WhenAll(tasks.Select(t => t.WithCancellation(token)));

                foreach (var responses in all)
                {
                    foreach (var resp in responses)
                    {
                        var rec = resp.Services.Values.FirstOrDefault();
                        if (rec == null) continue;

                        string host = resp.IPAddresses?
                            .FirstOrDefault(ip => IPAddress.TryParse(ip, out var a) && a.AddressFamily == AddressFamily.InterNetwork);

                        if (!string.IsNullOrWhiteSpace(host))
                            results.Add((host, rec.Port));
                    }
                }

                return results.Distinct().ToList();
            }
        }

