        private async void ConnectionCheckTimer_Tick(object? sender, EventArgs e)
        {
            if (_isConnCheckRunning) return; // 중복 실행 방지
            _isConnCheckRunning = true;
            try
            {
                // adb 출력 한 번만 파싱해서 상태 맵 구성
                string adbOutput = await Task.Run(() => RunCmd("adb devices", 3000));
                var lines = adbOutput.Split(new[] { '\r', '\n' }, StringSplitOptions.RemoveEmptyEntries);

                var statusMap = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase);
                foreach (var line in lines)
                {
                    var trimmed = line.Trim();
                    // 예상 포맷: "<addr>\t<status>" 또는 "<addr> <status>"
                    var parts = trimmed.Split(new[] { '\t', ' ' }, StringSplitOptions.RemoveEmptyEntries);
                    if (parts.Length >= 2)
                    {
                        var addr = parts[0];
                        var state = parts[^1];
                        if (state is "device" or "offline" or "unauthorized")
                        {
                            statusMap[addr] = state;
                        }
                    }
                }

                // 각 디바이스에 대해 miss 카운트 기반으로 상태 반영 (유예 기능)
                foreach (var device in Devices.ToList())
                {
                    var ip = device.Ip;
                    bool seen = statusMap.TryGetValue(ip, out var state);

                    if (seen && state.Equals("device", StringComparison.OrdinalIgnoreCase))
                    {
                        // 정상 응답: miss 카운트 리셋 및 즉시 Connected로 표시
                        lock (_missLock) { _missCounts[ip] = 0; }
                        if (!string.Equals(device.Status, "Connected", StringComparison.OrdinalIgnoreCase))
                            device.Status = "Connected";
                    }
                    else
                    {
                        int miss;
                        lock (_missLock)
                        {
                            if (!_missCounts.ContainsKey(ip)) _missCounts[ip] = 0;
                            _missCounts[ip] = _missCounts[ip] + 1;
                            miss = _missCounts[ip];
                        }

                        if (miss >= MissThreshold)
                        {
                            // 임계값 도달 시 실제로 오프라인 처리
                            if (seen)
                            {
                                device.Status = state.Equals("offline", StringComparison.OrdinalIgnoreCase) ? "Offline"
                                    : state.Equals("unauthorized", StringComparison.OrdinalIgnoreCase) ? "Unauthorized" : "Failed";
                            }
                            else
                            {
                                device.Status = "Failed";
                            }

                            if (device.Status == "Offline" || device.Status == "Failed")
                                ScheduleReconnect(device);
                        }
                        else
                        {
                            // 임계값 미만: 기존 상태 유지 (유예)
                        }
                    }
                }
            }
            finally
            {
                _isConnCheckRunning = false;
            }
        }

        private void ScheduleReconnect(Device device)
        {
            if (device == null || string.IsNullOrWhiteSpace(device.Ip)) return;

            ReconnectState st;
            lock (_reconnectStates)
            {
                if (!_reconnectStates.TryGetValue(device.Ip, out st))
                {
                    st = new ReconnectState { Attempt = 0, NextUtc = DateTime.MinValue, IsRunning = false };
                    _reconnectStates[device.Ip] = st;
                }

                // 아직 대기 시간
                if (st.IsRunning || DateTime.UtcNow < st.NextUtc) return;
                st.IsRunning = true;
            }

            _ = Task.Run(async () =>
            {
                bool ok = false;
                try
                {
                    ok = await TryReconnectDeviceAsync(device);
                }
                catch { }
                finally
                {
                    lock (_reconnectStates)
                    {
                        if (_reconnectStates.TryGetValue(device.Ip, out var s))
                        {
                            if (ok)
                            {
                                s.Attempt = 0;
                                s.NextUtc = DateTime.UtcNow.AddSeconds(2);
                            }
                            else
                            {
                                s.Attempt = Math.Min(s.Attempt + 1, 10);
                                // 지수 백오프 (최대 60초)
                                var delaySec = Math.Min(60, (int)Math.Pow(2, s.Attempt));
                                s.NextUtc = DateTime.UtcNow.AddSeconds(delaySec);
                            }
                            s.IsRunning = false;
                        }
                    }
                }
            });
        }

        private async Task<bool> TryReconnectDeviceAsync(Device device)
        {
            if (device == null) return false;

            // 1) 기존 주소로 재연결 시도
            string output = RunCmdWithRetry($"adb connect {device.Ip}", 1500, 2, 200);
            if (output.Contains("connected", StringComparison.OrdinalIgnoreCase) ||
                output.Contains("already connected", StringComparison.OrdinalIgnoreCase))
            {
                await Dispatcher.InvokeAsync(() => device.Status = "Connected");
                return true;
            }

            // 2) 간단한 정리 후 재시도
            RunCmd($"adb disconnect {device.Ip}", 1000);
            output = RunCmdWithRetry($"adb connect {device.Ip}", 1500, 2, 200);
            if (output.Contains("connected", StringComparison.OrdinalIgnoreCase) ||
                output.Contains("already connected", StringComparison.OrdinalIgnoreCase))
            {
                await Dispatcher.InvokeAsync(() => device.Status = "Connected");
                return true;
            }

            // 3) mDNS에서 동일 IP의 최신 포트 확인 후 재시도 (빠른 경로)
            try
            {
                var mdns = await AdbMdnsDiscovery.DiscoverAsync(2500);
                string ipOnly = device.Ip.Split(':')[0];
                var cand = mdns.FirstOrDefault(t => string.Equals(t.ip, ipOnly, StringComparison.OrdinalIgnoreCase));
                if (!string.IsNullOrEmpty(cand.ip) && cand.port > 0)
                {
                    string addr = $"{cand.ip}:{cand.port}";
                    string out2 = RunCmdWithRetry($"adb connect {addr}", 1500, 2, 200);
                    if (out2.Contains("connected", StringComparison.OrdinalIgnoreCase) ||
                        out2.Contains("already connected", StringComparison.OrdinalIgnoreCase))
                    {
                        await Dispatcher.InvokeAsync(() =>
                        {
                            device.Ip = addr; // 포트 갱신
                            device.Status = "Connected";
                        });
                        return true;
                    }
                }
            }
            catch { }

            // 4) 기본 포트(5555) 빠른 체크
            try
            {
                string ipOnly = device.Ip.Split(':')[0];
                if (await TryConnectPort(ipOnly, 5555, CancellationToken.None))
                {
                    string addr = $"{ipOnly}:5555";
                    string out3 = RunCmdWithRetry($"adb connect {addr}", 1500, 2, 200);
                    if (out3.Contains("connected", StringComparison.OrdinalIgnoreCase) ||
                        out3.Contains("already connected", StringComparison.OrdinalIgnoreCase))
                    {
                        await Dispatcher.InvokeAsync(() =>
                        {
                            device.Ip = addr;
                            device.Status = "Connected";
                        });
                        return true;
                    }
                }
            }
            catch { }

            return false;
        }

        private async void UpdateBatteryStatus(object? sender, EventArgs e)
