        private async void MirrorTile_Click(object sender, RoutedEventArgs e)
        {
            if ((sender as Button)?.CommandParameter is not Device device) return;
            if (!device.IsConnected) { MessageBox.Show("연결되지 않았습니다."); return; }

            var host = FindInItemTemplate<Border>(Tiles, device, "PART_MirrorHost");
            if (host == null) { MessageBox.Show("미러 호스트를 찾지 못했습니다."); return; }

            if (_scrcpy.TryGetValue(device.Ip, out var running) && !running.HasExited)
            {
                ScrcpyEmbedder.Adjust(running, host, this);
                return;
            }

            var proc = await StartMirroringWithSemaphoreAsync(device, (int)Math.Max(1, host.ActualWidth * 0.9f), (int)Math.Max(1, host.ActualHeight * 0.9f), CancellationToken.None);
            if (proc == null || proc.HasExited) { MessageBox.Show("미러링 시작 실패"); return; }

            lock (_mirrorLock)
            {
                _scrcpy[device.Ip] = proc;
            }
            proc.EnableRaisingEvents = true;
            proc.Exited += (s2, a2) => { lock (_mirrorLock) { _scrcpy.Remove(device.Ip); } };
            ScrcpyEmbedder.Attach(proc, host, this);
        }

        private async void RefreshTile_Click(object sender, RoutedEventArgs e)
        {
            if (_isRefreshing)
            {
                MessageBox.Show("이미 새로고침 중입니다.");
                return;
            }
            _isRefreshing = true;
            if ((sender as Button)?.CommandParameter is not Device device) { _isRefreshing = false; return; }

            // 기존 scrcpy 프로세스가 있으면 모두 종료
            lock (_mirrorLock)
            {
                if (_scrcpy.TryGetValue(device.Ip, out var old) && !old.HasExited)
                {
                    try { old.Kill(); } catch { }
                    _scrcpy.Remove(device.Ip);
                }
            }

            var host = FindInItemTemplate<Border>(Tiles, device, "PART_MirrorHost");
            if (host == null) { MessageBox.Show("미러 호스트를 찾지 못했습니다."); _isRefreshing = false; return; }

            var procNew = await StartMirroringWithSemaphoreAsync(device, (int)Math.Max(1, host.ActualWidth * 0.9f), (int)Math.Max(1, host.ActualHeight * 0.9f), CancellationToken.None);
            if (procNew == null || procNew.HasExited) { MessageBox.Show("미러링 시작 실패"); _isRefreshing = false; return; }

            lock (_mirrorLock)
            {
                _scrcpy[device.Ip] = procNew;
            }
            procNew.EnableRaisingEvents = true;
            procNew.Exited += (s2, a2) => { lock (_mirrorLock) { _scrcpy.Remove(device.Ip); } };
            ScrcpyEmbedder.Attach(procNew, host, this);
            _isRefreshing = false;
        }

        private void StopTile_Click(object sender, RoutedEventArgs e)
        {
            if ((sender as Button)?.CommandParameter is not Device device) return;
            StopMirrorForDevice(device);
        }

        private bool _isRefreshing = false;

        //====================== 디바이스 윈도우 영역 ======================

        private DeviceWindow _deviceWindow;
        private void OpenDeviceWindow(Device device)
        {
            if (device == null) return;

            // 1) 기존 창이 있으면 닫기
            if (_deviceWindow != null)
            {
                try { _deviceWindow.Closed -= DeviceWindow_Closed; } catch { }
                try { _deviceWindow.Close(); } catch { }
                _deviceWindow = null;
            }

            // 2) 새 창 열기
            var win = new DeviceWindow(this, device) { Owner = this };
            _deviceWindow = win;
            win.Closed += DeviceWindow_Closed;
            win.Show();
        }

        private void DeviceWindow_Closed(object? sender, EventArgs e)
        {
            // 빠르게 연달아 열었을 때 새 인스턴스를 건드리지 않게 보호
            if (ReferenceEquals(sender, _deviceWindow))
                _deviceWindow = null;
        }

