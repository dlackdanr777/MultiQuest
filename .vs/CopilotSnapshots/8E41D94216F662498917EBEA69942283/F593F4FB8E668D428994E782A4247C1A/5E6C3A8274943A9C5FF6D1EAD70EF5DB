        private void HookDevice(Device d)
        {
            d.PropertyChanged += Device_PropertyChanged;
            if (d.IsConnected) Dispatcher.BeginInvoke(new Action(() => StartMirrorForDevice(d)));
        }

        private void UnhookDevice(Device d)
        {
            d.PropertyChanged -= Device_PropertyChanged;
            StopMirrorForDevice(d);
