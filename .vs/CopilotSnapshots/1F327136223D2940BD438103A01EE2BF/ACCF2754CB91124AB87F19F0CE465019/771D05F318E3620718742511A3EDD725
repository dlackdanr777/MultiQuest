        // 후보 중 하나라도 실행에 성공하면 즉시 반환
        public async void StartApp(Device device, int index, Action onCompleted = null)
        {
            if (device == null || device.Status != "Connected") { ShowMsg("기기를 확인하세요."); return; }

            string activity = "com.unity3d.player.UnityPlayerActivity";
            string[] candidates = _pkgNames[index];

            await Task.Run(() =>
            {
                foreach (var pkg in candidates)
                {
                    string result = RunCmd($"adb -s {device.Ip} shell am start -n {pkg}/{activity}", 2000);
                    // "Error" 또는 "does not exist" 가 없으면 성공으로 판단
                    if (!result.Contains("Error", StringComparison.OrdinalIgnoreCase) &&
                        !result.Contains("does not exist", StringComparison.OrdinalIgnoreCase))
                    {
                        break; // 성공 → 이후 후보 시도 중단
                    }
                }
            });

            onCompleted?.Invoke();
        }

