        private void ItemContainerGenerator_StatusChanged(object? sender, EventArgs e)
        {
            if (Tiles.ItemContainerGenerator.Status != GeneratorStatus.ContainersGenerated) return;

            Dispatcher.BeginInvoke(new Action(() =>
            {
                foreach (var entry in _scrcpy)
                {
                    var device = Devices.FirstOrDefault(d => d.Ip == entry.Key && d.IsConnected);
                    if (device == null) continue;
                    var host = FindInItemTemplate<Border>(Tiles, device, "PART_MirrorHost");
                    if (host != null) ScrcpyEmbedder.Adjust(entry.Value, host, this);
                }
            }), DispatcherPriority.Loaded);
        }

        private void HookDevice(Device d)
        {
            d.PropertyChanged += Device_PropertyChanged;
            if (d.IsConnected) Dispatcher.BeginInvoke(new Action(() => StartMirrorForDevice(d)));
        }

        private void UnhookDevice(Device d)
        {
            d.PropertyChanged -= Device_PropertyChanged;
            StopMirrorForDevice(d);
        }

        private void Device_PropertyChanged(object? sender, PropertyChangedEventArgs e)
        {
            if (sender is not Device d) return;
            if (e.PropertyName == nameof(Device.Status) || e.PropertyName == nameof(Device.IsConnected))
            {
                if (d.IsConnected) StartMirrorForDevice(d);
                else StopMirrorForDevice(d);
            }
        }

        private readonly object _mirrorLock = new();

        // ★ 수정: IP별 중복 실행 방지 플래그(_mirrorStarting)로 async void 재진입 차단
        private async void StartMirrorForDevice(Device device)
        {
            lock (_mirrorLock)
            {
                // 이미 이 IP에 대해 미러링 시작 중이면 무시
                if (_mirrorStarting.Contains(device.Ip)) return;
                _mirrorStarting.Add(device.Ip);

                // 기존 프로세스가 있으면 먼저 종료
                if (_scrcpy.TryGetValue(device.Ip, out var old) && !old.HasExited)
                {
                    try { old.Kill(); } catch { }
                    _scrcpy.Remove(device.Ip);
                }
            }

            try
            {
                // host가 null이면 레이아웃이 아직 확정되지 않은 것 → 최대 5회 재시도
                Border host = null;
                for (int i = 0; i < 5; i++)
                {
                    host = FindInItemTemplate<Border>(Tiles, device, "PART_MirrorHost");
                    if (host != null && host.ActualWidth > 1 && host.ActualHeight > 1) break;
                    await Dispatcher.Yield(DispatcherPriority.Loaded);
                    await Task.Delay(100); // 레이아웃 안정화 대기
                }
                if (host == null) return;

                var proc = await StartMirroringWithSemaphoreAsync(device,
                    (int)Math.Max(1, host.ActualWidth),
                    (int)Math.Max(1, host.ActualHeight),
                    CancellationToken.None);
                if (proc == null || proc.HasExited || proc.MainWindowHandle == IntPtr.Zero) return;

                lock (_mirrorLock)
                {
                    // await 구간에 다른 프로세스가 이미 등록된 경우 새 것을 종료
                    if (_scrcpy.TryGetValue(device.Ip, out var existing) && existing != proc)
                    {
                        try { if (!proc.HasExited) proc.Kill(); } catch { }
                        return;
                    }
                    _scrcpy[device.Ip] = proc;
                }

                proc.EnableRaisingEvents = true;
                proc.Exited += (s2, a2) => { lock (_mirrorLock) { _scrcpy.Remove(device.Ip); } };

                // Win32 창이 완전히 렌더링될 때까지 짧게 대기 후 임베드
                // 서치 오버레이가 표시 중이면 Attach를 억제하고 pendingAttach에 등록
                // (HideSearchOverlay에서 Attach 처리)
                await Task.Delay(80);
                // 항상 Attach(SetParent+스타일 제거)를 먼저 수행해 임베드 상태로 만든다.
                // 스캔 중이거나 MetaDevice 패널이 아닌 경우에는 Attach 직후 창을 숨겨둔다.
                // → MetaDevice로 돌아올 때 ShowAll 한 번으로 정상 표시됨
                ScrcpyEmbedder.Attach(proc, host, this);
                if (_isScanning || PanelMetaDevice.Visibility != Visibility.Visible)
                {
                    ScrcpyEmbedder.HideWindow(proc.MainWindowHandle);
                    if (_isScanning)
                        lock (_mirrorLock) { _pendingAttach.Add(device.Ip); }
                }
            }
            finally
            {
                // 반드시 플래그 해제
                lock (_mirrorLock) { _mirrorStarting.Remove(device.Ip); }
            }
        }

        private void StopMirrorForDevice(Device device)
        {
            lock (_mirrorLock)
            {
                if (_scrcpy.TryGetValue(device.Ip, out var p))
                {
                    try
                    {
                        var hwnd = p.MainWindowHandle;
                        // Kill 전에 Win32 창 먼저 숨기기 — 입베드된 창이 화면에 남아 있는 문제 해결
                        if (hwnd != IntPtr.Zero)
                            ScrcpyEmbedder.HideWindow(hwnd);
                        if (!p.HasExited) p.Kill();
                    }
                    catch { }
                    _scrcpy.Remove(device.Ip);
                }
            }
        }

        // ★ 수정: Window_SizeChanged에서 직접 Adjust 대신 디바운스 타이머를 트리거
        // → 레이아웃이 완전히 재계산(PART_MirrorHost ActualWidth/Height 갱신)된 뒤 Adjust 실행
        private void Window_SizeChanged(object sender, SizeChangedEventArgs e)
        {
            if (e.PreviousSize == e.NewSize) return;

            // 크기 변화가 있으면 무조건 즉시 숨김
            // → 디바운스 300ms 동안 scrcpy 창이 이전 크기/위치로 남아 잔상이 생기는 문제 해결
            // → 확대 시에도 빈 영역에 이전 창이 잠깐 노출되는 현상 동일하게 방지
            ScrcpyEmbedder.HideAll(_scrcpy.Values);

            // 디바운스 완료 후 Adjust + ShowAll 로 재표시
            _tilesAdjustDebounce.Stop();
            _tilesAdjustDebounce.Start();
        }

        // ========== 안정화된 FindInItemTemplate ==========

        public T FindInItemTemplate<T>(ItemsControl itemsControl, object item, string elementName)
            where T : FrameworkElement
        {
            var container = itemsControl.ItemContainerGenerator.ContainerFromItem(item) as FrameworkElement;
            if (container == null)
            {
                // UpdateLayout은 전체 레이아웃 트리를 강제 재계산하므로 꼭 필요할 때만 호출
                if (itemsControl.ItemContainerGenerator.Status == System.Windows.Controls.Primitives.GeneratorStatus.ContainersGenerated)
                    itemsControl.UpdateLayout();
                container = itemsControl.ItemContainerGenerator.ContainerFromItem(item) as FrameworkElement;
                if (container == null) return null;
            }

            container.ApplyTemplate();

            if (container is ContentPresenter cp)
            {
                var tpl = cp.ContentTemplate ?? itemsControl.ItemTemplate;
                if (tpl != null)
                {
                    try
                    {
                        var el = tpl.FindName(elementName, cp) as T;
                        if (el != null) return el;
                    }
                    catch (InvalidOperationException)
                    {
                        // 템플릿 미적용 예외 → fallback
                    }
                }
            }

            return FindVisualChildByName<T>(container, elementName);
        }

        private static T FindVisualChildByName<T>(DependencyObject parent, string name)
            where T : FrameworkElement
        {
            int count = VisualTreeHelper.GetChildrenCount(parent);
            for (int i = 0; i < count; i++)
            {
                var child = VisualTreeHelper.GetChild(parent, i);
                if (child is T fe && fe.Name == name)
                    return fe;

                var result = FindVisualChildByName<T>(child, name);
                if (result != null) return result;
            }
            return null;
        }

