        private void OnClose(object sender, EventArgs e)
        {
            // 이벤트 구독 해제 및 타이머 정지
            try { SettingsService.Instance.Changed -= OnChangeSerialName; } catch { }
            try { _connectionCheckTimer?.Stop(); } catch { }
            try { _keyEventTimer?.Stop(); } catch { }
            try { _batteryCheckTimer?.Stop(); } catch { }

            // 비디오 월 창 닫기
            if (_multiMirrorWindow != null)
            {
                try { _multiMirrorWindow.Close(); } catch { }
                _multiMirrorWindow = null;
            }

            // scrcpy 프로세스 종료
            foreach (var proc in _scrcpy.Values)
            {
                try
                {
                    if (!proc.HasExited)
                    {
                        proc.Kill();
                    }
                }
                catch { }
                finally
                {
                    proc.Dispose();
                }
            }
            _scrcpy.Clear();

            // scrcpy.exe 종료
            try
            {
                foreach (var scrcpyProc in Process.GetProcessesByName("scrcpy"))
                {
                    scrcpyProc.Kill();
                    scrcpyProc.WaitForExit();
                }
            }
            catch (Exception ex)
            {
                Debug.WriteLine($"scrcpy 종료 중 오류 발생: {ex.Message}");
            }

            // 모든 adb.exe 프로세스 종료
            try
            {
                foreach (var adbProc in Process.GetProcessesByName("adb"))
                {
                    adbProc.Kill();
                    adbProc.WaitForExit();
                }
            }
            catch (Exception ex)
            {
                Debug.WriteLine($"adb 종료 중 오류 발생: {ex.Message}");
            }

            // adb kill-server 명령 실행
            try
            {
                var psi = new ProcessStartInfo
                {
                    FileName = _adbPath,
                    Arguments = "kill-server",
                    UseShellExecute = false,
                    CreateNoWindow = true
                };
                using (var process = Process.Start(psi))
                {
                    process.WaitForExit(2000);
                }
            }
            catch (Exception ex)
            {
                Debug.WriteLine($"adb kill-server 실행 중 오류 발생: {ex.Message}");
            }
        }

        private async Task<List<string>> FindAliveIpsAsync(string baseIp, string localIp, int ipStart, int ipEnd, ProgressWindow progress, CancellationToken token)
        {
            var aliveIps = new ConcurrentBag<string>();
            var allIps = Enumerable.Range(ipStart, ipEnd - ipStart + 1).Select(i => baseIp + i).ToList();
            int totalIp = allIps.Count;
            int done = 0;

            try
            {
                await Task.Run(() =>
                {
                    try
                    {
                        Parallel.ForEach(allIps, new ParallelOptions { MaxDegreeOfParallelism = 128, CancellationToken = token }, ip =>
                        {
                            if (token.IsCancellationRequested) return;
                            try
                            {
                                using var ping = new Ping();
                                var reply = ping.Send(ip, 200); // 300→200ms 단축
                                if (reply.Status == IPStatus.Success && ip != localIp)
                                    aliveIps.Add(ip);
                            }
                            catch { }

                            int d = Interlocked.Increment(ref done);
                            if (!token.IsCancellationRequested && (d % 20 == 0 || d == totalIp))
                                Dispatcher.BeginInvoke(() => progress.SetProgress(d, totalIp));
                        });
                    }
                    catch (OperationCanceledException) { }
                });
            }
            catch (OperationCanceledException) { }
            return aliveIps.ToList();
        }

        public async Task<List<(string ip, int port)>> ScanPortsAsync(
            List<string> ips, int portStart, int portEnd, IProgress<int> progress = null, CancellationToken token = default)
        {
            var openPorts = new ConcurrentBag<(string, int)>();
            int maxParallel = 400;
            var throttler = new SemaphoreSlim(maxParallel);
            var tasks = new List<Task>();
            int completed = 0, totalPort = ips.Count * (portEnd - portStart + 1);
            int reportInterval = Math.Max(totalPort / 100, 1);

            try
            {
                // 가능성 높은 5555 선탐색
                foreach (var ip in ips)
                {
                    if (token.IsCancellationRequested) break;
                    await throttler.WaitAsync(token);
                    tasks.Add(Task.Run(async () =>
                    {
                        try
                        {
                            if (await TryConnectPort(ip, 5555, token))
                                openPorts.Add((ip, 5555));
                        }
                        catch { }
                        finally
                        {
                            int done = Interlocked.Increment(ref completed);
                            if (done % reportInterval == 0 || done == totalPort)
                                progress?.Report(done);
                            throttler.Release();
                        }
                    }, token));
                }

                // 범위 스캔
                foreach (var ip in ips)
                {
                    for (int port = portStart; port <= portEnd; port++)
                    {
                        if (port == 5555) continue;
                        if (token.IsCancellationRequested) break;
                        await throttler.WaitAsync(token);
                        var t = ScanPortAsync(ip, port, openPorts, throttler, () =>
                        {
                            int done = Interlocked.Increment(ref completed);
                            if (done % reportInterval == 0 || done == totalPort)
                                progress?.Report(done);
                        }, token);
                        tasks.Add(t);
                    }
                }
                await Task.WhenAll(tasks);
            }
            catch (OperationCanceledException) { }
            return openPorts.ToList();
        }

        private async Task ScanPortAsync(string ip, int port, ConcurrentBag<(string, int)> openPorts, SemaphoreSlim throttler, Action onComplete, CancellationToken token)
        {
            try
            {
                if (token.IsCancellationRequested) return;
                if (await TryConnectPort(ip, port, token))
                    openPorts.Add((ip, port));
            }
            catch { }
            finally
            {
                onComplete?.Invoke();
                throttler.Release();
            }
        }

        private static async Task<bool> TryConnectPort(string ip, int port, CancellationToken token)
        {
            try
            {
                using var client = new TcpClient();
                var connectTask = client.ConnectAsync(ip, port);
                var timeoutTask = Task.Delay(200, token); // 150→200ms: 포트 탄지 실패륙 감소
                var completedTask = await Task.WhenAny(connectTask, timeoutTask);
                return completedTask == connectTask && client.Connected;
            }
            catch { return false; }
        }

