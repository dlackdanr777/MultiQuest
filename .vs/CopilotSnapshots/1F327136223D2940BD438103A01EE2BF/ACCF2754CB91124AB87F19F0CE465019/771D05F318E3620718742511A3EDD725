        // ====================== 공간 설정 초기화 ======================
        // Meta Quest OS v62+ 기준 실제 동작하는 방법 순서대로 시도:
        //
        // [방법 A] Guardian 데이터 파일 직접 삭제 (루트 불필요, ADB shell 권한으로 가능)
        //   - /data/data/com.oculus.guardian  (앱 데이터)
        //   - /sdcard/Android/data/com.oculus.guardian  (외부 저장소)
        //   삭제 후 com.oculus.guardian 프로세스를 kill → 재시작 시 빈 guardian으로 초기화됨
        //
        // [방법 B] Guardian 앱 데이터 클리어 (pm clear)
        //   adb shell pm clear com.oculus.guardian
        //   → 앱 데이터/캐시 전체 삭제, 공간 경계 초기화됨
        //
        // [방법 C] 시스템 재부팅
        //   adb shell reboot
        //   → 가장 확실, 단 재연결 필요
        //
        // 버튼 클릭 시 A → B 순서로 시도, 실패 시 C(재부팅) 여부를 사용자에게 묻는다
        private async void ResetGuardianBtn_Click(object sender, RoutedEventArgs e)
        {
            PlayClickSound();

            var connected = Devices.Where(d => d.Status == "Connected").ToList();
            if (connected.Count == 0) { ShowMsg("연결된 기기가 없습니다."); return; }

            const string resetAppPkg      = "com.StoryWing.ResetRoomDataApp";
            const string resetAppActivity = "com.unity3d.player.UnityPlayerActivity";

            var appResults = new ConcurrentBag<(string name, bool launched)>();
            await Task.Run(() =>
            {
                Parallel.ForEach(connected, new ParallelOptions { MaxDegreeOfParallelism = 8 }, device =>
                {
                    string result = RunCmd(
                        $"adb -s {device.Ip} shell am start -n {resetAppPkg}/{resetAppActivity}", 2000);
                    bool ok = !result.Contains("Error",          StringComparison.OrdinalIgnoreCase)
                           && !result.Contains("does not exist", StringComparison.OrdinalIgnoreCase)
                           && !result.Contains("Timeout",        StringComparison.OrdinalIgnoreCase);
                    appResults.Add((device.Name, ok));
                });
            });

            int successCount = appResults.Count(r => r.launched);
            int failCount    = appResults.Count(r => !r.launched);

            string summary = string.Join("\n", appResults
                .OrderBy(r => r.name)
                .Select(r => $"  {(r.launched ? "✅" : "❌")} {r.name}"));

            ShowMsg($"=== ResetRoomDataApp 실행 결과 ===\n\n{summary}\n\n" +
                    $"성공: {successCount}개  /  실패: {failCount}개");
        }

