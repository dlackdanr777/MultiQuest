        private async void ConnectionCheckTimer_Tick(object? sender, EventArgs e)
        {
            // adb 출력 한 번만 파싱해서 상태 맵 구성
            string adbOutput = await Task.Run(() => RunCmd("adb devices", 3000));
            var lines = adbOutput.Split(new[] { '\r', '\n' }, StringSplitOptions.RemoveEmptyEntries);

            var statusMap = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase);
            foreach (var line in lines)
            {
                var trimmed = line.Trim();
                // 예상 포맷: "<addr>\t<status>" 또는 "<addr> <status>"
                var parts = trimmed.Split(new[] { '\t', ' ' }, StringSplitOptions.RemoveEmptyEntries);
                if (parts.Length >= 2)
                {
                    var addr = parts[0];
                    var state = parts[^1];
                    if (state is "device" or "offline" or "unauthorized")
                    {
                        statusMap[addr] = state;
                    }
                }
            }

            foreach (var device in Devices.ToList())
            {
                if (statusMap.TryGetValue(device.Ip, out var state))
                {
                    device.Status = state.Equals("device", StringComparison.OrdinalIgnoreCase)
                        ? "Connected"
                        : state.Equals("offline", StringComparison.OrdinalIgnoreCase)
                            ? "Offline"
                            : state.Equals("unauthorized", StringComparison.OrdinalIgnoreCase)
                                ? "Unauthorized" : "Failed";
                }
                else
                {
                    device.Status = "Failed";
                }
            }
        }

        private async void UpdateBatteryStatus(object? sender, EventArgs e)
        {
            foreach (var device in Devices.ToList())
            {
                if (device == null || device.Status != "Connected") continue;

                try
                {
                    int batteryLevel = await Task.Run(() => GetBatteryLevel(device.Ip));
                    Dispatcher.Invoke(() =>
                    {
                        Device d = Devices.FirstOrDefault(d => d.Ip == device.Ip);
                        if (d == null) return; // 이미 제거된 경우
                        d.BatteryLevel = batteryLevel;
                    });
                }
                catch
                {
                    Dispatcher.Invoke(() =>
                    {
                        Device d = Devices.FirstOrDefault(d => d.Ip == device.Ip);
                        if (d == null) return; // 이미 제거된 경우
                        d.BatteryLevel = 0;
                    });
                }
            }
        }

        private void OnChangeSerialName(IReadOnlyDictionary<string, string> serialNameDic)
        {
            foreach (var device in Devices)
            {
                if (serialNameDic.TryGetValue(device.Serial, out var name))
                {
                    if (device.Name?.Contains(name) == true) continue;
                    device.Name = name;
                }
                else
                {
                    device.Name = device.Serial; // 시리얼을 이름으로 사용
                }
            }
        }

