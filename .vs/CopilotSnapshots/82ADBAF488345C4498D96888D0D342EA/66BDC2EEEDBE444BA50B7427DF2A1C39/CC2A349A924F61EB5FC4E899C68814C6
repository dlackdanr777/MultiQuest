        public async void AddDevice(string name, string ip)
        {
            this.IsEnabled = false;
            if (_scanCancelSource != null && !_scanCancelSource.IsCancellationRequested)
            {
                ShowMsg("다른 작업을 진행중입니다.");
                this.IsEnabled = true;
                return;
            }

            if (Devices.Any(d => d.Ip.Split(':')[0] == ip))
            {
                ShowMsg($"{ip} 기기는 이미 연결되어 있습니다.");
                this.IsEnabled = true;
                return;
            }

            int portStart = 30000, portEnd = 49999;
            int totalPort = portEnd - portStart + 1;
            var progress = new ProgressWindow(this);
            progress.Owner = this;
            progress.ShowInTaskbar = true;
            progress.Show();

            try
            {
                var openPorts = await ScanPortsAsync(
                    new List<string> { ip }, portStart, portEnd,
                    new Progress<int>((done) => progress.SetProgress(done, totalPort)));

                bool connected = false;
                foreach (var (openIp, port) in openPorts)
                {
                    string addr = $"{openIp}:{port}";
                    string output = RunCmdWithRetry($"adb connect {addr}", 1200, 3, 200);

                    if (output.Contains("connected", StringComparison.OrdinalIgnoreCase) ||
                        output.Contains("already connected", StringComparison.OrdinalIgnoreCase))
                    {
                        connected = true;
                        AddDevice(new Device { Serial = name, Ip = addr, Status = "Connected" });
                        ShowMsg($"{name} 기기가 성공적으로 연결되었습니다.\nIP: {addr}");
                        break;
                    }
                }

                if (!connected) ShowMsg($"{name} 기기 연결 실패: 열려있는 포트가 없거나 연결에 실패했습니다.");
            }
            catch (Exception ex)
            {
                ShowMsg("기기 추가 중 오류가 발생했습니다: " + ex.Message);
            }
            finally
            {
                progress.Close();
                this.IsEnabled = true;
            }
        }

        private void AddDevice(Device device)
        {
            if (device == null || string.IsNullOrEmpty(device.Ip)) { ShowMsg("유효하지 않은 기기 정보입니다."); return; }
            if (Devices.Any(d => d.Ip == device.Ip)) { ShowMsg($"{device.Name} 기기는 이미 목록에 있습니다."); return; }
            if (device.Status != "Connected") { ShowMsg($"{device.Name} 기기가 연결되어 있지 않습니다."); return; }
            device.BatteryLevel = GetBatteryLevel(device.Ip); // 배터리 잔량 초기화
            string Name = _serialNameDic.TryGetValue(device.Serial, out string name) ? name : device.Serial;
            device.Name = Name;

            Devices.Add(device);          // 컬렉션에 추가하면 HookDevice에서 자동 미러링 시작
            AddDeviceEvent?.Invoke(device);
        }

        public int GetBatteryLevel(string deviceIp)
        {
            int maxRetry = 3, retryDelayMs = 300;
            for (int attempt = 1; attempt <= maxRetry; attempt++)
            {
                try
                {
                    string output = RunCmd($"adb -s {deviceIp} shell dumpsys battery", 2000);
                    var lines = output.Split(new[] { '\r', '\n' }, StringSplitOptions.RemoveEmptyEntries);
                    foreach (var line in lines)
                    {
                        if (line.Trim().StartsWith("level:"))
                        {
                            var parts = line.Split(new[] { ':' }, StringSplitOptions.RemoveEmptyEntries);
                            if (parts.Length == 2 && int.TryParse(parts[1].Trim(), out int batteryLevel))
                                return batteryLevel;
                        }
                    }
                }
                catch (Exception ex) { Debug.WriteLine($"배터리 잔량 가져오기 실패 (시도 {attempt}/{maxRetry}): {ex.Message}"); }
                if (attempt < maxRetry) Thread.Sleep(retryDelayMs);
            }
            return -1;
        }

