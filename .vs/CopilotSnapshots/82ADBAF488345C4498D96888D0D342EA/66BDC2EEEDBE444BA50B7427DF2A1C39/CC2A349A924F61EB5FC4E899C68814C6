        // 현재 살아있는 scrcpy 프로세스들을 각 디바이스의 PART_MirrorHost에 맞춰 재부착/재정렬
        private void AdjustAllEmbeddedScrcpy()
        {
            foreach (var kv in _scrcpy.ToList())
            {
                var ip = kv.Key;
                var proc = kv.Value;
                try
                {
                    if (proc == null || proc.HasExited) continue;
                    var device = Devices.FirstOrDefault(d => d.Ip == ip && d.IsConnected);
                    if (device == null) continue;
                    var host = FindInItemTemplate<Border>(Tiles, device, "PART_MirrorHost");
                    if (host != null)
                    {
                        ScrcpyEmbedder.Adjust(proc, host, this);
                    }
                }
                catch { }
            }
        }

        // ====================== ADB 초기 스캔 ======================

        private void InitializeConnectedDevices()
        {
            string adbOutput = RunCmd("adb devices", 3000);
            var lines = adbOutput.Split(new[] { '\r', '\n' }, StringSplitOptions.RemoveEmptyEntries);

            foreach (var line in lines)
            {
                if (line.TrimEnd().EndsWith("device"))
                {
                    var parts = line.Split(new[] { '\t', ' ' }, StringSplitOptions.RemoveEmptyEntries);
                    if (parts.Length > 0)
                    {
                        string ip = parts[0];
                        if (!Devices.Any(d => d.Ip == ip))
                        {
                            string serial = RunCmdWithRetry($"adb -s {ip} shell getprop ro.serialno", 1000, 5, 300).Trim();
                            if (string.IsNullOrEmpty(serial) || serial.Contains("not found") || serial.StartsWith("adb.exe"))
                                serial = "UnknownSerial";

                            AddDevice(new Device
                            {
                                Serial = serial,
                                Ip = ip,
                                Status = "Connected"
                            });
                        }
                    }
                }
            }
        }

