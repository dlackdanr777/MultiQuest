        private async void MdnsDiscoveryButton_Click(object sender, RoutedEventArgs e)
        {
            this.IsEnabled = false;
            _scanCancelSource = new CancellationTokenSource();
            var token = _scanCancelSource.Token;

            var progress = new ProgressWindow(this);
            progress.Closed += (s, args) => _scanCancelSource?.Cancel();
            progress.Closed += (s, args) =>
            {
                this.Activate();
                this.IsEnabled = true;
            };

            progress.Owner = this;
            progress.ShowInTaskbar = true;
            progress.Show();

            try
            {
                int foundByMdns = 0;
                int maxAttempts = 5; // 최대 탐색 시도 횟수
                int delayBetweenAttemptsMs = 1000; // 각 탐색 사이의 대기 시간 (밀리초)

                for (int attempt = 1; attempt <= maxAttempts; attempt++)
                {
                    if (token.IsCancellationRequested) break;
                    progress.SetProgress(attempt, maxAttempts);
                    // ★ mDNS 탐색
                    try
                    {
                        var mdns = await AdbMdnsDiscovery.DiscoverAsync(token, 5000); // ← 토큰 전달
                        if (!token.IsCancellationRequested && mdns.Count > 0)
                        {
                            await Task.Run(() =>
                            {
                                try
                                {
                                    Parallel.ForEach(mdns, new ParallelOptions { MaxDegreeOfParallelism = 8, CancellationToken = token }, tuple =>
                                    {
                                        if (token.IsCancellationRequested) return;

                                        var addr = $"{tuple.ip}:{tuple.port}";
                                        string output = RunCmdWithRetry($"adb connect {addr}", 1500, 5, 300);
                                        if (token.IsCancellationRequested) return;

                                        if (output.Contains("connected", StringComparison.OrdinalIgnoreCase) ||
                                            output.Contains("already connected", StringComparison.OrdinalIgnoreCase))
                                        {
                                            string serial = RunCmdWithRetry($"adb -s {addr} shell getprop ro.serialno", 1200, 3, 200).Trim();
                                            if (string.IsNullOrWhiteSpace(serial) || serial.Contains("not found") || serial.StartsWith("adb.exe"))
                                                serial = "UnknownSerial";

                                            if (serial != "UnknownSerial")
                                            {
                                                Dispatcher.Invoke(() =>
                                                {
                                                    if (!Devices.Any(d => d.Ip == addr))
                                                    {
                                                        AddDevice(new Device { Serial = serial, Ip = addr, Status = "Connected" });
                                                        Interlocked.Increment(ref foundByMdns);
                                                    }
                                                });
                                            }
                                        }
                                    });
                                }
                                catch (OperationCanceledException)
                                {
                                    // 작업이 취소된 경우 안전하게 종료
                                    Debug.WriteLine("Parallel.ForEach 작업이 취소되었습니다.");
                                }
                            }, token);
                        }
                    }
                    catch (OperationCanceledException)
                    {
                        // 사용자가 닫았으므로 즉시 종료
                        return;
                    }

                    // 다음 탐색 시도 전 대기
                    if (attempt < maxAttempts)
                    {
                        try
                        {
                            await Task.Delay(delayBetweenAttemptsMs, token);
                        }
                        catch (TaskCanceledException)
                        {
                            // 작업이 취소된 경우 안전하게 종료
                            Debug.WriteLine("mDNS 탐색이 취소되었습니다.");
                            break;
                        }
                    }
                }

                if (!token.IsCancellationRequested)
                {
                    Dispatcher.Invoke(() =>
                    {
                        ShowMsg($"mDNS 탐색 완료 - 총 발견된 디바이스: {foundByMdns}개");
                    });
                }
            }
            finally
            {
                if (progress.IsVisible) progress.Close();
                this.IsEnabled = true;
            }
        }

