        //====================== 디바이스 윈도우 영역 ======================

        private DeviceWindow _deviceWindow;
        private void OpenDeviceWindow(Device device)
        {
            if (device == null) return;

            // 1) 기존 창이 있으면 닫기
            if (_deviceWindow != null)
            {
                try { _deviceWindow.Closed -= DeviceWindow_Closed; } catch { }
                try { _deviceWindow.Close(); } catch { }
                _deviceWindow = null;
            }

            // 2) 새 창 열기
            var win = new DeviceWindow(this, device) { Owner = this };
            _deviceWindow = win;
            win.Closed += DeviceWindow_Closed;
            win.Show();
        }

        private void DeviceWindow_Closed(object? sender, EventArgs e)
        {
            // 빠르게 연달아 열었을 때 새 인스턴스를 건드리지 않게 보호
            if (ReferenceEquals(sender, _deviceWindow))
                _deviceWindow = null;
        }

