    // ====================== mDNS ADB TLS 디스커버리 ======================
    public static class AdbMdnsDiscovery
    {
        private static readonly string[] Services = new[]
        {
            "_adb-tls-connect._tcp.local.",
            "_adb_secure_connect._tcp.local."
        };

        public static Task<List<(string ip, int port)>> DiscoverAsync(int mdnsTimeoutMs = 5000)
            => DiscoverAsync(CancellationToken.None, mdnsTimeoutMs);

        public static async Task<List<(string ip, int port)>> DiscoverAsync(CancellationToken token, int mdnsTimeoutMs = 5000)
        {
            var results = new List<(string, int)>();
            var tasks = Services.Select(svc =>
                ZeroconfResolver.ResolveAsync(svc, scanTime: TimeSpan.FromMilliseconds(mdnsTimeoutMs))).ToArray();
            var all = await Task.WhenAll(tasks.Select(t => t.WithCancellation(token)));

            foreach (var responses in all)
            {
                foreach (var resp in responses)
                {
                    var rec = resp.Services.Values.FirstOrDefault();
                    if (rec == null) continue;

                    string host = resp.IPAddresses?
                        .FirstOrDefault(ip => IPAddress.TryParse(ip, out var a) && a.AddressFamily == AddressFamily.InterNetwork);

                    if (!string.IsNullOrWhiteSpace(host))
                        results.Add((host, rec.Port));
                }
            }

            return results.Distinct().ToList();
        }
    }

    // ====================== Device ======================
    public class Device : INotifyPropertyChanged
    {
        private string _name;
        private string _serial;
        private string _ip;
        private string _status;
        private int _batteryLevel = -1;

        public string Name
        {
            get => _name;
            set { if (_name != value) { _name = value; OnPropertyChanged(); } }
        }

        public string Serial
        {
            get => _serial;
            set { if (_serial != value) { _serial = value; } }
        }

        public string Ip
        {
            get => _ip;
            set { if (_ip != value) { _ip = value; OnPropertyChanged(); } }
        }

        public string Status
        {
            get => _status;
            set { if (_status != value) { _status = value; OnPropertyChanged(); OnPropertyChanged(nameof(IsConnected)); } }
        }

        public int BatteryLevel
        {
            get => _batteryLevel;
            set { if (_batteryLevel != value) { _batteryLevel = value; OnPropertyChanged(); OnPropertyChanged(nameof(BatteryText)); } }
        }

        public bool IsConnected => string.Equals(Status, "Connected", StringComparison.OrdinalIgnoreCase);
        public string BatteryText => BatteryLevel >= 0 ? $"{BatteryLevel}%" : "N/A";

        public event PropertyChangedEventHandler PropertyChanged;
        protected void OnPropertyChanged([CallerMemberName] string prop = null)
            => PropertyChanged?.Invoke(this, new PropertyChangedEventArgs(prop));

        public override bool Equals(object obj) => obj is Device d && Ip == d.Ip;
        public override int GetHashCode() => Ip != null ? Ip.GetHashCode() : 0;
    }

    internal static class TaskExtensions
    {
        public static async Task<T> WithCancellation<T>(this Task<T> task, CancellationToken token)
        {
            var tcs = new TaskCompletionSource<bool>(TaskCreationOptions.RunContinuationsAsynchronously);
            using (token.Register(static s => ((TaskCompletionSource<bool>)s!).TrySetResult(true), tcs))
            {
                if (task == await Task.WhenAny(task, tcs.Task).ConfigureAwait(false))
                    return await task.ConfigureAwait(false);
                throw new OperationCanceledException(token);
            }
        }
    }
