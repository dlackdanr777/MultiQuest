        // mDNS 이후 보강: 기존 Connected 유지, 신규만 추가
        private async Task<int> IpAugmentScanAsync(ProgressWindow progress, CancellationToken token)
        {
            string localIp = GetLocalIPv4();
            if (string.IsNullOrEmpty(localIp))
            {
                Dispatcher.Invoke(() => ShowMsg("로컬 IP를 감지할 수 없습니다."));
                return 0;
            }

            string[] ipParts = localIp.Split('.');
            string baseIp = $"{ipParts[0]}.{ipParts[1]}.{ipParts[2]}.";

            int ipStart = 2, ipEnd = 254;
            int portStart = 30000, portEnd = 49999;

            // 이미 연결/추가된 IP:PORT는 제외
            var existingAddrs = new HashSet<string>(Devices.Select(d => d.Ip), StringComparer.OrdinalIgnoreCase);
            var existingIps = new HashSet<string>(existingAddrs.Select(a => a.Split(':')[0]), StringComparer.OrdinalIgnoreCase);

            // 1) alive IP 수집
            List<string> aliveIps = null;
            try { aliveIps = await FindAliveIpsAsync(baseIp, localIp, ipStart, ipEnd, progress, token); }
            catch (OperationCanceledException) { return 0; }

            // alive 0이면 /24 전체 저강도 스캔 (샤오미 대비)
            if (aliveIps.Count == 0)
            {
                aliveIps = Enumerable.Range(ipStart, ipEnd - ipStart + 1)
                    .Select(i => baseIp + i)
                    .Where(ip => ip != localIp)
                    .ToList();
            }

            // 이미 알고 있는 IP는 제외 (중복 스캔 억제)
            aliveIps = aliveIps.Where(ip => !existingIps.Contains(ip)).ToList();
            if (aliveIps.Count == 0) return 0;

            int totalPort = aliveIps.Count * (portEnd - portStart + 1);

            // 2) 포트 스캔
            List<(string ip, int port)> openPorts = null;
            try
            {
                Debug.WriteLine($"대상 IP 개수: {aliveIps.Count}, 포트 범위: {portStart}-{portEnd}");
                openPorts = await ScanPortsAsync(
                    aliveIps, portStart, portEnd,
                    new Progress<int>(v => progress.SetProgress(v, totalPort)), token);
            }
            catch (OperationCanceledException) { return 0; }

            if (token.IsCancellationRequested) return 0;

            // 3) 열린 포트로 ADB 연결 시도
            int foundCount = 0;
            try
            {
                await Task.Run(() =>
                {
                    Parallel.ForEach(openPorts, new ParallelOptions { MaxDegreeOfParallelism = 32, CancellationToken = token }, target =>
                    {
                        if (token.IsCancellationRequested) return;

                        string addr = $"{target.ip}:{target.port}";
                        if (existingAddrs.Contains(addr)) return; // 이미 있는 경우 skip

                        string output = RunCmdWithRetry($"adb connect {addr}", 1200, 5, 250);
                        if (output.Contains("connected", StringComparison.OrdinalIgnoreCase) ||
                            output.Contains("already connected", StringComparison.OrdinalIgnoreCase))
                        {
                            string serial = RunCmdWithRetry($"adb -s {addr} shell getprop ro.serialno", 1200, 3, 200).Trim();
                            if (string.IsNullOrWhiteSpace(serial) || serial.Contains("not found") || serial.StartsWith("adb.exe"))
                                serial = "UnknownSerial";

                            if (serial != "UnknownSerial")
                            {
                                Dispatcher.Invoke(() =>
                                {
                                    if (!Devices.Any(d => d.Ip == addr))
                                    {
                                        AddDevice(new Device { Serial = serial, Ip = addr, Status = "Connected" });
                                        Interlocked.Increment(ref foundCount);
                                    }
                                });
                            }
                        }
                    });
                }, token);
            }
            catch (OperationCanceledException) { return foundCount; }

            return foundCount;
        }

