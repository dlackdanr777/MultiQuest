                                <Image Source="Images/SmartFarm.png" Stretch="UniformToFill" RenderOptions.BitmapScalingMode="HighQuality"/>
                            </Button>
                            <Button Style="{StaticResource AppIconBtn}" Click="AllDeviceStartAppBtn_Click" Tag="10">
