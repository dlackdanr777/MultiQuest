                            <Image Source="Images/Coding.png" Stretch="UniformToFill" RenderOptions.BitmapScalingMode="HighQuality"/>
                        </Button>
                    </UniformGrid>
                </Border>

                <!-- ── 패널 3: XR English프로그램 ── -->
                <Border x:Name="PanelXrEnglish" Visibility="Collapsed"
                        Background="#E8650A" CornerRadius="0" Margin="12">
                    <Border Background="#111827" CornerRadius="20" Margin="4">
                        <UniformGrid Rows="2" Columns="5" Margin="12">
                            <Button Style="{StaticResource AppIconBtn}" Click="AllDeviceStartAppBtn_Click" Tag="3">
                                <Image Source="Images/EnglishTown.png" Stretch="UniformToFill" RenderOptions.BitmapScalingMode="HighQuality"/>
                            </Button>
                            <Button Style="{StaticResource AppIconBtn}" Click="AllDeviceStartAppBtn_Click" Tag="3">
                                <Image Source="Images/EnglishTown.png" Stretch="UniformToFill" RenderOptions.BitmapScalingMode="HighQuality"/>
                            </Button>
                            <Button Style="{StaticResource AppIconBtn}" Click="AllDeviceStartAppBtn_Click" Tag="3">
                                <Image Source="Images/EnglishTown.png" Stretch="UniformToFill" RenderOptions.BitmapScalingMode="HighQuality"/>
                            </Button>
                            <Button Style="{StaticResource AppIconBtn}" Click="AllDeviceStartAppBtn_Click" Tag="3">
                                <Image Source="Images/EnglishTown.png" Stretch="UniformToFill" RenderOptions.BitmapScalingMode="HighQuality"/>
                            </Button>
                            <Button Style="{StaticResource AppIconBtn}" Click="AllDeviceStartAppBtn_Click" Tag="3">
                                <Image Source="Images/EnglishTown.png" Stretch="UniformToFill" RenderOptions.BitmapScalingMode="HighQuality"/>
                            </Button>
                            <Button Style="{StaticResource AppIconBtn}" Click="AllDeviceStartAppBtn_Click" Tag="3">
                                <Image Source="Images/EnglishTown.png" Stretch="UniformToFill" RenderOptions.BitmapScalingMode="HighQuality"/>
                            </Button>
                            <Button Style="{StaticResource AppIconBtn}" Click="AllDeviceStartAppBtn_Click" Tag="3">
                                <Image Source="Images/EnglishTown.png" Stretch="UniformToFill" RenderOptions.BitmapScalingMode="HighQuality"/>
                            </Button>
                            <Button Style="{StaticResource AppIconBtn}" Click="AllDeviceStartAppBtn_Click" Tag="3">
                                <Image Source="Images/EnglishTown.png" Stretch="UniformToFill" RenderOptions.BitmapScalingMode="HighQuality"/>
                            </Button>
                            <Button Style="{StaticResource AppIconBtn}" Click="AllDeviceStartAppBtn_Click" Tag="3">
                                <Image Source="Images/EnglishTown.png" Stretch="UniformToFill" RenderOptions.BitmapScalingMode="HighQuality"/>
                            </Button>
                            <Button Style="{StaticResource AppIconBtn}" Click="AllDeviceStartAppBtn_Click" Tag="3">
                                <Image Source="Images/EnglishTown.png" Stretch="UniformToFill" RenderOptions.BitmapScalingMode="HighQuality"/>
                            </Button>
                        </UniformGrid>
                    </Border>
                </Border>

                <!-- ── 패널 4: Meta Device (미러링 타일 4×4) ── -->
                <Border x:Name="PanelMetaDevice" Visibility="Collapsed"
                        Background="#111827" CornerRadius="0" Margin="0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <ItemsControl x:Name="Tiles" ItemsSource="{Binding Devices}" Margin="4">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Rows="4" Columns="4"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type local:Device}">
                                    <Border Style="{StaticResource TileCard}">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition/>
                                            </Grid.RowDefinitions>
                                            <Grid Grid.Row="0" Margin="6,4,6,2">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                    <Ellipse Width="8" Height="8" Margin="0,0,5,0">
                                                        <Ellipse.Style>
                                                            <Style TargetType="Ellipse">
                                                                <Setter Property="Fill" Value="{StaticResource Bad}"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                                                        <Setter Property="Fill" Value="{StaticResource Ok}"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Ellipse.Style>
                                                    </Ellipse>
                                                    <TextBlock Text="{Binding Name}" Foreground="{StaticResource Text}"
                                                               FontWeight="SemiBold" FontSize="11"
                                                               TextTrimming="CharacterEllipsis" MaxWidth="80"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                                    <Grid Width="32" Height="32" Margin="0,0,4,0" IsHitTestVisible="False">
                                                        <Image Source="Images/Battery.png" Stretch="Fill"/>
                                                        <TextBlock Text="{Binding BatteryText}"
                                                                   Foreground="{StaticResource Text}"
                                                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                   FontSize="9" FontWeight="Bold"/>
                                                    </Grid>
                                                    <Button Content="Refresh" Style="{StaticResource NeonMini}"
                                                            Click="RefreshTile_Click" CommandParameter="{Binding}"/>
                                                    <Button Content="Open" Style="{StaticResource NeonMini}"
                                                            Margin="3,0,0,0"
                                                            Click="OpenDeviceBtn_Click" CommandParameter="{Binding}"/>
                                                    <Button Content="✕" Width="16" Height="16" Margin="4,0,0,0"
                                                            Padding="0" FontSize="10"
                                                            Foreground="{StaticResource Bad}"
                                                            Background="Transparent" BorderBrush="Transparent"
                                                            Cursor="Hand" ToolTip="디바이스 삭제"
                                                            Click="DeleteDeviceBtn_Click" CommandParameter="{Binding}"/>
                                                </StackPanel>
                                            </Grid>
                                            <Border x:Name="PART_MirrorHost" Grid.Row="1"
                                                    Style="{StaticResource MirrorSurface}" Margin="4,2,4,4"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </Border>

            </Grid>
        </Border>

        <!-- ── 검색 중 오버레이 ── -->
        <Grid x:Name="SearchOverlay"
              Grid.Column="1"
              Visibility="Collapsed"
              Background="#E8650A">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Width="200">
                <Grid Width="120" Height="120" Margin="0,0,0,20">
                    <Ellipse Width="120" Height="120" Stroke="#C45500" StrokeThickness="10"/>
                    <Viewbox Width="120" Height="120" Stretch="None">
                        <Path x:Name="SpinnerArc"
                              Stroke="White" StrokeThickness="10"
                              StrokeStartLineCap="Round" StrokeEndLineCap="Round">
                            <Path.Data>
                                <PathGeometry>
                                    <PathFigure StartPoint="60,5" IsClosed="False">
                                        <ArcSegment Point="5,60" Size="55,55" SweepDirection="Clockwise" IsLargeArc="True"/>
                                    </PathFigure>
                                </PathGeometry>
                            </Path.Data>
                            <Path.RenderTransform>
                                <RotateTransform x:Name="SpinnerRotate" Angle="0" CenterX="60" CenterY="60"/>
                            </Path.RenderTransform>
                        </Path>
                    </Viewbox>
                    <TextBlock x:Name="SearchPercentText" Text="0%" Foreground="White"
                               FontSize="22" FontWeight="Bold"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Grid>
                <TextBlock x:Name="SearchStatusText" Text="디바이스 탐색 중..."
                           Foreground="White" FontSize="14" FontWeight="SemiBold" TextAlignment="Center"/>
            </StackPanel>
            <Button Content="취소"
                    Click="SearchCancelBtn_Click"
                    HorizontalAlignment="Center" VerticalAlignment="Bottom"
                    Margin="0,0,0,30" Width="100" Height="36"
                    FontSize="13" FontWeight="Bold"
                    Foreground="#E8650A" Background="White" BorderBrush="Transparent" BorderThickness="0">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border CornerRadius="10" Background="{TemplateBinding Background}" Padding="10,6">
                            <Border.RenderTransform><ScaleTransform x:Name="scale" ScaleX="1" ScaleY="1"/></Border.RenderTransform>
                            <Border.RenderTransformOrigin>0.5,0.5</Border.RenderTransformOrigin>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <EventTrigger RoutedEvent="Button.PreviewMouseLeftButtonDown">
                                <BeginStoryboard><Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="scale" Storyboard.TargetProperty="ScaleX" To="0.93" Duration="0:0:0.08"/>
                                    <DoubleAnimation Storyboard.TargetName="scale" Storyboard.TargetProperty="ScaleY" To="0.93" Duration="0:0:0.08"/>
                                </Storyboard></BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="Button.PreviewMouseLeftButtonUp">
                                <BeginStoryboard><Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="scale" Storyboard.TargetProperty="ScaleX" To="1" Duration="0:0:0.12"/>
                                    <DoubleAnimation Storyboard.TargetName="scale" Storyboard.TargetProperty="ScaleY" To="1" Duration="0:0:0.12"/>
                                </Storyboard></BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="Button.MouseLeave">
                                <BeginStoryboard><Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="scale" Storyboard.TargetProperty="ScaleX" To="1" Duration="0:0:0.12"/>
                                    <DoubleAnimation Storyboard.TargetName="scale" Storyboard.TargetProperty="ScaleY" To="1" Duration="0:0:0.12"/>
                                </Storyboard></BeginStoryboard>
                            </EventTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </Grid>

    </Grid>
</Window>

    <!-- ================== 글로벌 리소스(팔레트/스타일) ================== -->
    <Window.Resources>
        <!-- Palette -->
        <SolidColorBrush x:Key="Bg0"      Color="#0E1116"/>
        <SolidColorBrush x:Key="Card"     Color="#141A24"/>
        <SolidColorBrush x:Key="Card2"    Color="#0F1622"/>
        <SolidColorBrush x:Key="Stroke"   Color="#223047"/>
        <SolidColorBrush x:Key="Ok"       Color="#3CE48C"/>
        <SolidColorBrush x:Key="Bad"      Color="#FF5963"/>
        <SolidColorBrush x:Key="Text"     Color="#D8E2F1"/>
        <SolidColorBrush x:Key="TextDim"  Color="#9DB0C9"/>
        <SolidColorBrush x:Key="SideBar"  Color="#4A7EC7"/>
        <SolidColorBrush x:Key="SideBtn"  Color="#6A9FD8"/>
        <SolidColorBrush x:Key="SideBtnActive" Color="#1E4A8A"/>

        <!-- 사이드바 메뉴 버튼 -->
        <Style x:Key="SideMenuBtn" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize"   Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor"     Value="Hand"/>
            <Setter Property="Margin"     Value="10,6"/>
            <Setter Property="Background" Value="{StaticResource SideBtn}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" CornerRadius="14"
                                Background="{TemplateBinding Background}"
                                Padding="10,14">
                            <Border.RenderTransform>
                                <ScaleTransform x:Name="scale" ScaleX="1" ScaleY="1"/>
                            </Border.RenderTransform>
                            <Border.RenderTransformOrigin>0.5,0.5</Border.RenderTransformOrigin>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <EventTrigger RoutedEvent="Button.PreviewMouseLeftButtonDown">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="scale"
                                                         Storyboard.TargetProperty="ScaleX"
                                                         To="0.92" Duration="0:0:0.08"/>
                                        <DoubleAnimation Storyboard.TargetName="scale"
                                                         Storyboard.TargetProperty="ScaleY"
                                                         To="0.92" Duration="0:0:0.08"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="Button.PreviewMouseLeftButtonUp">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="scale"
                                                         Storyboard.TargetProperty="ScaleX"
                                                         To="1" Duration="0:0:0.12"/>
                                        <DoubleAnimation Storyboard.TargetName="scale"
                                                         Storyboard.TargetProperty="ScaleY"
                                                         To="1" Duration="0:0:0.12"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="Button.MouseLeave">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="scale"
                                                         Storyboard.TargetProperty="ScaleX"
                                                         To="1" Duration="0:0:0.12"/>
                                        <DoubleAnimation Storyboard.TargetName="scale"
                                                         Storyboard.TargetProperty="ScaleY"
                                                         To="1" Duration="0:0:0.12"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="{StaticResource SideBtnActive}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 활성 사이드바 버튼 -->
        <Style x:Key="SideMenuBtnActive" BasedOn="{StaticResource SideMenuBtn}" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource SideBtnActive}"/>
        </Style>

        <!-- 슬롯(타일) 카드 -->
        <Style x:Key="TileCard" TargetType="Border">
            <Setter Property="CornerRadius"   Value="12"/>
            <Setter Property="Background"     Value="{StaticResource Card2}"/>
            <Setter Property="BorderBrush"    Value="{StaticResource Stroke}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin"         Value="4"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
        </Style>

        <!-- 미러 표면 -->
        <Style x:Key="MirrorSurface" TargetType="Border">
            <Setter Property="CornerRadius"   Value="8"/>
            <Setter Property="BorderBrush"    Value="#253447"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#0D1420" Offset="0"/>
                        <GradientStop Color="#0B1019" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 네온 미니 버튼 (타일 내) -->
        <Style x:Key="NeonMini" TargetType="Button">
            <Setter Property="Foreground"     Value="{StaticResource Text}"/>
            <Setter Property="FontSize"       Value="11"/>
            <Setter Property="FontWeight"     Value="SemiBold"/>
            <Setter Property="Padding"        Value="8,3"/>
            <Setter Property="MinWidth"       Value="54"/>
            <Setter Property="Height"         Value="22"/>
            <Setter Property="Cursor"         Value="Hand"/>
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#2A2F3C" Offset="0"/>
                        <GradientStop Color="#1A2230" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="BorderBrush"    Value="#2B3B56"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border CornerRadius="6"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 앱 아이콘 버튼 -->
        <Style x:Key="AppIconBtn" TargetType="Button">
            <Setter Property="Background"     Value="Transparent"/>
            <Setter Property="BorderBrush"    Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"         Value="Hand"/>
            <Setter Property="Margin"         Value="4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" CornerRadius="16"
                                Background="{TemplateBinding Background}"
                                Padding="4">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#33FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#55FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 콘텐츠 패널 배경 -->
        <Style x:Key="ContentPanel" TargetType="Border">
            <Setter Property="Background"     Value="#1A2535"/>
            <Setter Property="CornerRadius"   Value="18"/>
            <Setter Property="Margin"         Value="8"/>
        </Style>
    </Window.Resources>

    <!-- ================== 본문: 사이드바 + 콘텐츠 ================== -->
    <Grid>
        <Grid.ColumnDefinitions>
            <!-- 왼쪽 사이드바 -->
            <ColumnDefinition Width="160"/>
            <!-- 오른쪽 콘텐츠 -->
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ====== 왼쪽 사이드바 ====== -->
        <Border Grid.Column="0" Background="#4A7EC7" CornerRadius="0,0,0,0">
            <DockPanel>
                <!-- 상단 설정 메뉴 -->
                <Menu DockPanel.Dock="Top" Background="Transparent" Margin="8,8,8,0">
                    <MenuItem Header="⚙ 설정" Foreground="White" FontWeight="Bold" FontSize="13">
                        <MenuItem Header="이름 설정" Click="OpenSettings_Click"/>
                    </MenuItem>
                </Menu>

                <!-- 사이드 버튼들 -->
                <StackPanel VerticalAlignment="Top" Margin="0,16,0,0">
                    <!-- Meta Device 버튼 -->
                    <Button x:Name="BtnMetaDevice"
                            Style="{StaticResource SideMenuBtn}"
                            Click="BtnMetaDevice_Click">
                        <TextBlock TextAlignment="Center" LineHeight="22">
                            <Run Text="Meta" FontSize="17"/><LineBreak/>
                            <Run Text="Device" FontSize="17"/>
                        </TextBlock>
                    </Button>

                    <!-- XR체험프로그램 버튼 -->
                    <Button x:Name="BtnXrExperience"
                            Style="{StaticResource SideMenuBtn}"
                            Click="BtnXrExperience_Click">
                        <TextBlock TextAlignment="Center" LineHeight="22">
                            <Run Text="XR체험" FontSize="17"/><LineBreak/>
                            <Run Text="프로그램" FontSize="17"/>
                        </TextBlock>
                    </Button>

                    <!-- XR Coding프로그램 버튼 -->
                    <Button x:Name="BtnXrCoding"
                            Style="{StaticResource SideMenuBtn}"
                            Click="BtnXrCoding_Click">
                        <TextBlock TextAlignment="Center" LineHeight="22">
                            <Run Text="XR Coding" FontSize="17"/><LineBreak/>
                            <Run Text="프로그램" FontSize="17"/>
                        </TextBlock>
                    </Button>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ====== 오른쪽 콘텐츠 영역 ====== -->
        <Grid Grid.Column="1">

            <!-- ── 패널 1: Meta Device (미러링 타일 그리드) ── -->
            <Border x:Name="PanelMetaDevice" Style="{StaticResource ContentPanel}" Visibility="Visible">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- 4×4 디바이스 타일 -->
                    <ItemsControl x:Name="Tiles" ItemsSource="{Binding Devices}" Margin="4">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Rows="4" Columns="4"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>

                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type local:Device}">
                                <Border Style="{StaticResource TileCard}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition/>
                                        </Grid.RowDefinitions>

                                        <!-- 타일 헤더 -->
                                        <Grid Grid.Row="0" Margin="6,4,6,2">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- 이름 + 상태 -->
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                <Ellipse Width="8" Height="8" Margin="0,0,5,0">
                                                    <Ellipse.Style>
                                                        <Style TargetType="Ellipse">
                                                            <Setter Property="Fill" Value="{StaticResource Bad}"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                                                    <Setter Property="Fill" Value="{StaticResource Ok}"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Ellipse.Style>
                                                </Ellipse>
                                                <TextBlock Text="{Binding Name}" Foreground="{StaticResource Text}"
                                                           FontWeight="SemiBold" FontSize="11"
                                                           TextTrimming="CharacterEllipsis" MaxWidth="80"/>
                                            </StackPanel>

                                            <!-- 배터리 + 버튼들 -->
                                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                                <Grid Width="32" Height="32" Margin="0,0,4,0" IsHitTestVisible="False">
                                                    <Image Source="Images/Battery.png" Stretch="Fill"/>
                                                    <TextBlock Text="{Binding BatteryText}"
                                                               Foreground="{StaticResource Text}"
                                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                                               FontSize="9" FontWeight="Bold"/>
                                                </Grid>
                                                <Button Content="Refresh" Style="{StaticResource NeonMini}"
                                                        Click="RefreshTile_Click" CommandParameter="{Binding}"/>
                                                <Button Content="Open" Style="{StaticResource NeonMini}"
                                                        Margin="3,0,0,0"
                                                        Click="OpenDeviceBtn_Click" CommandParameter="{Binding}"/>
                                                <Button Content="✕" Width="16" Height="16" Margin="4,0,0,0"
                                                        Padding="0" FontSize="10"
                                                        Foreground="{StaticResource Bad}"
                                                        Background="Transparent" BorderBrush="Transparent"
                                                        Cursor="Hand" ToolTip="디바이스 삭제"
                                                        Click="DeleteDeviceBtn_Click" CommandParameter="{Binding}"/>
                                            </StackPanel>
                                        </Grid>

                                        <!-- 미러 호스트 -->
                                        <Border x:Name="PART_MirrorHost" Grid.Row="1"
                                                Style="{StaticResource MirrorSurface}" Margin="4,2,4,4"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- 우측 하단 Search Device 버튼 -->
                    <Button Grid.Row="1"
                            Content="🔍 Search Device"
                            Click="MdnsDiscoveryButton_Click"
                            HorizontalAlignment="Right"
                            Margin="12,6,12,12"
                            Width="180" Height="44"
                            FontSize="15" FontWeight="Bold"
                            Foreground="{StaticResource Text}"
                            Background="#1E3A5F" BorderBrush="#4A7EC7" BorderThickness="1.5">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bg" CornerRadius="12"
                                        Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}">
                                    <Border.RenderTransform>
                                        <ScaleTransform x:Name="scale" ScaleX="1" ScaleY="1"/>
                                    </Border.RenderTransform>
                                    <Border.RenderTransformOrigin>0.5,0.5</Border.RenderTransformOrigin>
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <EventTrigger RoutedEvent="Button.PreviewMouseLeftButtonDown">
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="scale" Storyboard.TargetProperty="ScaleX" To="0.93" Duration="0:0:0.08"/>
                                                <DoubleAnimation Storyboard.TargetName="scale" Storyboard.TargetProperty="ScaleY" To="0.93" Duration="0:0:0.08"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                    <EventTrigger RoutedEvent="Button.PreviewMouseLeftButtonUp">
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="scale" Storyboard.TargetProperty="ScaleX" To="1" Duration="0:0:0.12"/>
                                                <DoubleAnimation Storyboard.TargetName="scale" Storyboard.TargetProperty="ScaleY" To="1" Duration="0:0:0.12"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                    <EventTrigger RoutedEvent="Button.MouseLeave">
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="scale" Storyboard.TargetProperty="ScaleX" To="1" Duration="0:0:0.12"/>
                                                <DoubleAnimation Storyboard.TargetName="scale" Storyboard.TargetProperty="ScaleY" To="1" Duration="0:0:0.12"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bg" Property="Opacity" Value="0.85"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- 스피너 회전 애니메이션은 코드비하인드에서 제어 -->
                </Grid>
            </Border>

            <!-- ── 패널 2: XR체험프로그램 (앱 아이콘 그리드) ── -->
            <Border x:Name="PanelXrExperience" Style="{StaticResource ContentPanel}" Visibility="Collapsed">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- 앱 아이콘 2행 5열 (XR체험 10개) -->
                    <Border Grid.Row="0" Background="#111827" CornerRadius="14" Margin="12,12,12,6">
                        <UniformGrid Rows="2" Columns="5" Margin="8">
                            <!-- Row 0 -->
                            <Button Style="{StaticResource AppIconBtn}" Click="AllDeviceStartAppBtn_Click" Tag="3">
                                <Image Source="Images/EnglishTown.png" Stretch="Uniform"/>
                            </Button>
                            <Button Style="{StaticResource AppIconBtn}" Click="AllDeviceStartAppBtn_Click" Tag="2">
                                <Image Source="Images/OceanAdventure.png" Stretch="Uniform"/>
                            </Button>
                            <Button Style="{StaticResource AppIconBtn}" Click="AllDeviceStartAppBtn_Click" Tag="4">
                                <Image Source="/KoreaHistory.png" Stretch="Uniform"/>
                            </Button>
                            <Button Style="{StaticResource AppIconBtn}" Click="AllDeviceStartAppBtn_Click" Tag="1">
                                <Image Source="Images/SolarSystem.png" Stretch="Uniform"/>
                            </Button>
                            <Button Style="{StaticResource AppIconBtn}" Click="AllDeviceStartAppBtn_Click" Tag="0">
                                <Image Source="Images/FireSafety.png" Stretch="Uniform"/>
                            </Button>
                            <!-- Row 1 -->
                            <Button Style="{StaticResource AppIconBtn}" Click="AllDeviceStartAppBtn_Click" Tag="5">
                                <Image Source="/Images/SmartFarm.png" Stretch="Uniform"/>
                            </Button>
                            <Button Style="{StaticResource AppIconBtn}" Click="AllDeviceStartAppBtn_Click" Tag="6">
                                <Image Source="/BrainPop.png" Stretch="Uniform"/>
                            </Button>
                            <Button Style="{StaticResource AppIconBtn}" Click="AllDeviceStartAppBtn_Click" Tag="7">
                                <Image Source="/Images/SmartFarm.png" Stretch="Uniform"/>
                            </Button>
                            <Button Style="{StaticResource AppIconBtn}" Click="AllDeviceStartAppBtn_Click" Tag="10">
                                <Image Source="/Images/Musium.png" Stretch="Uniform"/>
                            </Button>
                            <Button Style="{StaticResource AppIconBtn}" Click="AllDeviceStartAppBtn_Click" Tag="9">
                                <Image Source="/Images/SmartFarm.png" Stretch="Uniform"/>
                            </Button>
                        </UniformGrid>
                    </Border>

                    <!-- All Stop 버튼 -->
                    <Button Grid.Row="1" Content="All Device Stop"
                            Click="AllDeviceStopAppBtn_Click"
                            HorizontalAlignment="Right" Margin="12,0,12,12"
                            Width="180" Height="44" FontSize="16" FontWeight="Bold"
                            Foreground="{StaticResource Bad}"
                            Background="#1A2535" BorderBrush="#FF5963" BorderThickness="1.5">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border CornerRadius="12"
                                        Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>

            <!-- ── 패널 3: XR Coding프로그램 ── -->
            <Border x:Name="PanelXrCoding" Style="{StaticResource ContentPanel}" Visibility="Collapsed">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- 코딩 앱 아이콘 -->
                    <Border Grid.Row="0" Background="#111827" CornerRadius="14" Margin="12,12,12,6">
                        <UniformGrid Rows="1" Columns="3" Margin="8">
                            <Button Style="{StaticResource AppIconBtn}" Click="AllDeviceStartAppBtn_Click" Tag="11">
                                <Image Source="/Images/Coding.png" Stretch="Uniform"/>
                            </Button>
                            <Button Style="{StaticResource AppIconBtn}" Click="AllDeviceStartAppBtn_Click" Tag="8">
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock Text="오션 관람" Foreground="White" FontWeight="Bold" FontSize="16" TextAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource AppIconBtn}" Click="AllDeviceStartAppBtn_Click" Tag="9">
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock Text="우주 관람" Foreground="White" FontWeight="Bold" FontSize="16" TextAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </UniformGrid>
                    </Border>

                    <!-- All Stop 버튼 -->
                    <Button Grid.Row="1" Content="All Device Stop"
                            Click="AllDeviceStopAppBtn_Click"
                            HorizontalAlignment="Right" Margin="12,0,12,12"
                            Width="180" Height="44" FontSize="16" FontWeight="Bold"
                            Foreground="{StaticResource Bad}"
                            Background="#1A2535" BorderBrush="#FF5963" BorderThickness="1.5">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border CornerRadius="12"
                                        Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>

        </Grid>

        <!-- ── 검색 중 오버레이: 최상위 Grid에 배치하여 IsEnabled 상속 차단 ── -->
        <Grid x:Name="SearchOverlay"
              Grid.Column="1"
              Visibility="Collapsed"
              Background="#E8650A">

            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                        Width="200">

                <!-- 원형 스피너 -->
                <Grid Width="120" Height="120" Margin="0,0,0,20">
                    <!-- 배경 트랙 -->
                    <Ellipse Width="120" Height="120"
                             Stroke="#C45500" StrokeThickness="10"/>

                    <!-- 회전하는 호 -->
                    <Viewbox Width="120" Height="120" Stretch="None">
                        <Path x:Name="SpinnerArc"
                              Stroke="White" StrokeThickness="10"
                              StrokeStartLineCap="Round" StrokeEndLineCap="Round">
                            <Path.Data>
                                <PathGeometry>
                                    <PathFigure StartPoint="60,5" IsClosed="False">
                                        <ArcSegment Point="5,60"
                                                    Size="55,55"
                                                    SweepDirection="Clockwise"
                                                    IsLargeArc="True"/>
                                    </PathFigure>
                                </PathGeometry>
                            </Path.Data>
                            <Path.RenderTransform>
                                <RotateTransform x:Name="SpinnerRotate"
                                                 Angle="0"
                                                 CenterX="60" CenterY="60"/>
                            </Path.RenderTransform>
                        </Path>
                    </Viewbox>

                    <!-- 중앙 퍼센트 텍스트 -->
                    <TextBlock x:Name="SearchPercentText"
                               Text="0%"
                               Foreground="White"
                               FontSize="22" FontWeight="Bold"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Grid>

                <!-- 안내 메시지 -->
                <TextBlock x:Name="SearchStatusText"
                           Text="디바이스 탐색 중..."
                           Foreground="White"
                           FontSize="14" FontWeight="SemiBold"
                           TextAlignment="Center"/>
            </StackPanel>

            <!-- 취소 버튼 -->
            <Button Content="취소"
                    Click="SearchCancelBtn_Click"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Bottom"
                    Margin="0,0,0,30"
                    Width="100" Height="36"
                    FontSize="13" FontWeight="Bold"
                    Foreground="#E8650A"
                    Background="White" BorderBrush="Transparent" BorderThickness="0">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border CornerRadius="10"
                                Background="{TemplateBinding Background}"
                                Padding="10,6">
                            <Border.RenderTransform>
                                <ScaleTransform x:Name="scale" ScaleX="1" ScaleY="1"/>
                            </Border.RenderTransform>
                            <Border.RenderTransformOrigin>0.5,0.5</Border.RenderTransformOrigin>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <EventTrigger RoutedEvent="Button.PreviewMouseLeftButtonDown">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="scale" Storyboard.TargetProperty="ScaleX" To="0.93" Duration="0:0:0.08"/>
                                        <DoubleAnimation Storyboard.TargetName="scale" Storyboard.TargetProperty="ScaleY" To="0.93" Duration="0:0:0.08"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="Button.PreviewMouseLeftButtonUp">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="scale" Storyboard.TargetProperty="ScaleX" To="1" Duration="0:0:0.12"/>
                                        <DoubleAnimation Storyboard.TargetName="scale" Storyboard.TargetProperty="ScaleY" To="1" Duration="0:0:0.12"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="Button.MouseLeave">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="scale" Storyboard.TargetProperty="ScaleX" To="1" Duration="0:0:0.12"/>
                                        <DoubleAnimation Storyboard.TargetName="scale" Storyboard.TargetProperty="ScaleY" To="1" Duration="0:0:0.12"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </Grid>

    </Grid>
</Window>