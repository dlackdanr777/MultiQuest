                    <!-- Meta Device 버튼 -->
                    <Button x:Name="BtnMetaDevice"
                            Height="110"
                            Style="{StaticResource SideMenuBtn}"
                            Click="BtnMetaDevice_Click">
                        <Image Source="Images/SideBtn_MetaDevice.png"
                               Stretch="Uniform" Margin="6"
                               RenderOptions.BitmapScalingMode="HighQuality"/>
                    </Button>
                </StackPanel>
            </DockPanel>
        </Border>

