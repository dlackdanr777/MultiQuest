<Window x:Class="MultiQuest_Management.MainWindow"
xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
xmlns:local="clr-namespace:MultiQuest_Management"
Title="MultiQuest Management" Height="750" Width="1280"
Background="#1A1A1A"
UseLayoutRounding="True"
TextOptions.TextFormattingMode="Display"
TextOptions.TextRenderingMode="ClearType">

    <Window.Resources>
        <!-- Palette -->
        <SolidColorBrush x:Key="Ok"       Color="#3CE48C"/>
        <SolidColorBrush x:Key="Bad"      Color="#FF5963"/>
        <SolidColorBrush x:Key="Text"     Color="#D8E2F1"/>
        <SolidColorBrush x:Key="Stroke"   Color="#223047"/>
        <SolidColorBrush x:Key="Card2"    Color="#0F1622"/>
        <SolidColorBrush x:Key="SideBtnNormal" Color="#555555"/>
        <SolidColorBrush x:Key="SideBtnActive" Color="#F5A623"/>

        <!-- 사이드바 메뉴 버튼 (이미지 전용) -->
        <Style x:Key="SideMenuBtn" TargetType="Button">
            <Setter Property="Background"     Value="{StaticResource SideBtnNormal}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"         Value="Hand"/>
            <Setter Property="Margin"         Value="8,4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" CornerRadius="12"
                                Background="{TemplateBinding Background}">
                            <Border.RenderTransform>
                                <ScaleTransform x:Name="scale" ScaleX="1" ScaleY="1"/>
                            </Border.RenderTransform>
                            <Border.RenderTransformOrigin>0.5,0.5</Border.RenderTransformOrigin>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <EventTrigger RoutedEvent="Button.PreviewMouseLeftButtonDown">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="scale" Storyboard.TargetProperty="ScaleX" To="0.92" Duration="0:0:0.08"/>
                                        <DoubleAnimation Storyboard.TargetName="scale" Storyboard.TargetProperty="ScaleY" To="0.92" Duration="0:0:0.08"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="Button.PreviewMouseLeftButtonUp">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="scale" Storyboard.TargetProperty="ScaleX" To="1" Duration="0:0:0.12"/>
                                        <DoubleAnimation Storyboard.TargetName="scale" Storyboard.TargetProperty="ScaleY" To="1" Duration="0:0:0.12"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="Button.MouseLeave">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="scale" Storyboard.TargetProperty="ScaleX" To="1" Duration="0:0:0.12"/>
                                        <DoubleAnimation Storyboard.TargetName="scale" Storyboard.TargetProperty="ScaleY" To="1" Duration="0:0:0.12"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 활성 사이드바 버튼 -->
        <Style x:Key="SideMenuBtnActive" BasedOn="{StaticResource SideMenuBtn}" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource SideBtnActive}"/>
        </Style>

        <!-- 슬롯(타일) 카드 -->
        <Style x:Key="TileCard" TargetType="Border">
            <Setter Property="CornerRadius"    Value="12"/>
            <Setter Property="Background"      Value="{StaticResource Card2}"/>
            <Setter Property="BorderBrush"     Value="{StaticResource Stroke}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin"          Value="4"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#AAAAAA" Direction="270" ShadowDepth="2" BlurRadius="12" Opacity="0.25"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 미러 표면 -->
        <Style x:Key="MirrorSurface" TargetType="Border">
            <Setter Property="CornerRadius"    Value="8"/>
            <Setter Property="BorderBrush"     Value="#253447"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#0D1420" Offset="0"/>
                        <GradientStop Color="#0B1019" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 네온 미니 버튼 (타일 내) -->
        <Style x:Key="NeonMini" TargetType="Button">
            <Setter Property="Foreground"      Value="{StaticResource Text}"/>
            <Setter Property="FontSize"        Value="11"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Padding"         Value="8,3"/>
            <Setter Property="MinWidth"        Value="54"/>
            <Setter Property="Height"          Value="22"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#2A2F3C" Offset="0"/>
                        <GradientStop Color="#1A2230" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="BorderBrush"     Value="#2B3B56"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border CornerRadius="6"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 앱 아이콘 버튼: 라운딩 + 비율 유지 -->
        <Style x:Key="AppIconBtn" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderBrush"     Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Margin"          Value="6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" CornerRadius="18" ClipToBounds="True"
                                Background="{TemplateBinding Background}">
                            <Border.RenderTransform>
                                <ScaleTransform x:Name="scale" ScaleX="1" ScaleY="1"/>
                            </Border.RenderTransform>
                            <Border.RenderTransformOrigin>0.5,0.5</Border.RenderTransformOrigin>
                            <Viewbox Stretch="UniformToFill">
                                <ContentPresenter/>
                            </Viewbox>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <EventTrigger RoutedEvent="Button.PreviewMouseLeftButtonDown">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="scale" Storyboard.TargetProperty="ScaleX" To="0.93" Duration="0:0:0.08"/>
                                        <DoubleAnimation Storyboard.TargetName="scale" Storyboard.TargetProperty="ScaleY" To="0.93" Duration="0:0:0.08"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="Button.PreviewMouseLeftButtonUp">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="scale" Storyboard.TargetProperty="ScaleX" To="1" Duration="0:0:0.12"/>
                                        <DoubleAnimation Storyboard.TargetName="scale" Storyboard.TargetProperty="ScaleY" To="1" Duration="0:0:0.12"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="Button.MouseLeave">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="scale" Storyboard.TargetProperty="ScaleX" To="1" Duration="0:0:0.12"/>
                                        <DoubleAnimation Storyboard.TargetName="scale" Storyboard.TargetProperty="ScaleY" To="1" Duration="0:0:0.12"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- ================== 본문: 사이드바 + 콘텐츠 ================== -->
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="160"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ====== 왼쪽 사이드바 ====== -->
        <Border Grid.Column="0" Background="#1A1A1A">
            <Border.Effect>
                <DropShadowEffect Color="#AAAAAA" Direction="0" ShadowDepth="0" BlurRadius="18" Opacity="0.4"/>
            </Border.Effect>
            <DockPanel>
                <!-- 상단 설정 메뉴 -->
                <Menu DockPanel.Dock="Top" Background="Transparent" Margin="8,8,8,0">
                    <MenuItem Header="⚙ 설정" Foreground="White" FontWeight="Bold" FontSize="13">
                        <MenuItem Header="이름 설정" Click="OpenSettings_Click"/>
                    </MenuItem>
                </Menu>

                <!-- 하단 Search Device + Program Stop -->
                <StackPanel DockPanel.Dock="Bottom" Margin="8,0,8,10">
                    <!-- Search Device -->
                    <Button x:Name="BtnSearchDevice"
                            Height="80" Margin="0,4"
                            Click="MdnsDiscoveryButton_Click">
                        <Button.Effect>
                            <DropShadowEffect Color="#AAAAAA" Direction="270" ShadowDepth="0" BlurRadius="14" Opacity="0.5"/>
                        </Button.Effect>
                        <Button.Style>
                            <Style BasedOn="{StaticResource SideMenuBtn}" TargetType="Button">
                                <Setter Property="Background" Value="#1E4A8A"/>
                            </Style>
                        </Button.Style>
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border CornerRadius="12" ClipToBounds="True">
                                    <Border x:Name="bg" CornerRadius="12">
                                        <Border.RenderTransform><ScaleTransform x:Name="scale" ScaleX="1" ScaleY="1"/></Border.RenderTransform>
                                        <Border.RenderTransformOrigin>0.5,0.5</Border.RenderTransformOrigin>
                                        <Border.Background>
                                            <ImageBrush ImageSource="Images/SearchIcon.png" Stretch="UniformToFill"
                                                        RenderOptions.BitmapScalingMode="HighQuality"/>
                                        </Border.Background>
                                    </Border>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="bg" Property="Opacity" Value="0.85"/></Trigger>
                                    <EventTrigger RoutedEvent="Button.PreviewMouseLeftButtonDown">
                                        <BeginStoryboard><Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="scale" Storyboard.TargetProperty="ScaleX" To="0.92" Duration="0:0:0.08"/>
                                            <DoubleAnimation Storyboard.TargetName="scale" Storyboard.TargetProperty="ScaleY" To="0.92" Duration="0:0:0.08"/>
                                        </Storyboard></BeginStoryboard>
                                    </EventTrigger>
                                    <EventTrigger RoutedEvent="Button.PreviewMouseLeftButtonUp">
                                        <BeginStoryboard><Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="scale" Storyboard.TargetProperty="ScaleX" To="1" Duration="0:0:0.12"/>
                                            <DoubleAnimation Storyboard.TargetName="scale" Storyboard.TargetProperty="ScaleY" To="1" Duration="0:0:0.12"/>
                                        </Storyboard></BeginStoryboard>
                                    </EventTrigger>
                                    <EventTrigger RoutedEvent="Button.MouseLeave">
                                        <BeginStoryboard><Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="scale" Storyboard.TargetProperty="ScaleX" To="1" Duration="0:0:0.12"/>
                                            <DoubleAnimation Storyboard.TargetName="scale" Storyboard.TargetProperty="ScaleY" To="1" Duration="0:0:0.12"/>
                                        </Storyboard></BeginStoryboard>
                                    </EventTrigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- Program Stop -->
                    <Button Height="80" Margin="0,4"
                            Click="AllDeviceStopAppBtn_Click">
                        <Button.Effect>
                            <DropShadowEffect Color="#AAAAAA" Direction="270" ShadowDepth="0" BlurRadius="14" Opacity="0.4"/>
                        </Button.Effect>
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border CornerRadius="12" ClipToBounds="True">
                                    <Border x:Name="bg" CornerRadius="12">
                                        <Border.RenderTransform><ScaleTransform x:Name="scale" ScaleX="1" ScaleY="1"/></Border.RenderTransform>
                                        <Border.RenderTransformOrigin>0.5,0.5</Border.RenderTransformOrigin>
                                        <Border.Background>
                                            <ImageBrush ImageSource="Images/StopIcon.png" Stretch="UniformToFill"
                                                        RenderOptions.BitmapScalingMode="HighQuality"/>
                                        </Border.Background>
                                    </Border>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="bg" Property="Opacity" Value="0.85"/></Trigger>
                                    <EventTrigger RoutedEvent="Button.PreviewMouseLeftButtonDown">
                                        <BeginStoryboard><Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="scale" Storyboard.TargetProperty="ScaleX" To="0.92" Duration="0:0:0.08"/>
                                            <DoubleAnimation Storyboard.TargetName="scale" Storyboard.TargetProperty="ScaleY" To="0.92" Duration="0:0:0.08"/>
                                        </Storyboard></BeginStoryboard>
                                    </EventTrigger>
                                    <EventTrigger RoutedEvent="Button.PreviewMouseLeftButtonUp">
                                        <BeginStoryboard><Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="scale" Storyboard.TargetProperty="ScaleX" To="1" Duration="0:0:0.12"/>
                                            <DoubleAnimation Storyboard.TargetName="scale" Storyboard.TargetProperty="ScaleY" To="1" Duration="0:0:0.12"/>
                                        </Storyboard></BeginStoryboard>
                                    </EventTrigger>
                                    <EventTrigger RoutedEvent="Button.MouseLeave">
                                        <BeginStoryboard><Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="scale" Storyboard.TargetProperty="ScaleX" To="1" Duration="0:0:0.12"/>
                                            <DoubleAnimation Storyboard.TargetName="scale" Storyboard.TargetProperty="ScaleY" To="1" Duration="0:0:0.12"/>
                                        </Storyboard></BeginStoryboard>
                                    </EventTrigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>

                <!-- 사이드 버튼들 (이미지만) -->
                <StackPanel VerticalAlignment="Top" Margin="8,12,8,0">
                    <!-- Meta Device 버튼 -->
                    <Button x:Name="BtnMetaDevice"
                            Height="80" Margin="8,4"
                            Click="BtnMetaDevice_Click">
                        <Button.Effect>
                            <DropShadowEffect Color="#AAAAAA" Direction="270" ShadowDepth="0" BlurRadius="16" Opacity="0.55"/>
                        </Button.Effect>
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border CornerRadius="12" ClipToBounds="True">
                                    <Border x:Name="bg" CornerRadius="12">
                                        <Border.RenderTransform><ScaleTransform x:Name="scale" ScaleX="1" ScaleY="1"/></Border.RenderTransform>
                                        <Border.RenderTransformOrigin>0.5,0.5</Border.RenderTransformOrigin>
                                        <Border.Background>
                                            <ImageBrush ImageSource="pack://application:,,,/Images/MultiScreen.png" Stretch="UniformToFill"
                                                        RenderOptions.BitmapScalingMode="HighQuality"/>
                                        </Border.Background>
                                    </Border>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="bg" Property="Opacity" Value="0.85"/></Trigger>
                                    <EventTrigger RoutedEvent="Button.PreviewMouseLeftButtonDown">
                                        <BeginStoryboard><Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="scale" Storyboard.TargetProperty="ScaleX" To="0.92" Duration="0:0:0.08"/>
                                            <DoubleAnimation Storyboard.TargetName="scale" Storyboard.TargetProperty="ScaleY" To="0.92" Duration="0:0:0.08"/>
                                        </Storyboard></BeginStoryboard>
                                    </EventTrigger>
                                    <EventTrigger RoutedEvent="Button.PreviewMouseLeftButtonUp">
                                        <BeginStoryboard><Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="scale" Storyboard.TargetProperty="ScaleX" To="1" Duration="0:0:0.12"/>
                                            <DoubleAnimation Storyboard.TargetName="scale" Storyboard.TargetProperty="ScaleY" To="1" Duration="0:0:0.12"/>
                                        </Storyboard></BeginStoryboard>
                                    </EventTrigger>
                                    <EventTrigger RoutedEvent="Button.MouseLeave">
                                        <BeginStoryboard><Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="scale" Storyboard.TargetProperty="ScaleX" To="1" Duration="0:0:0.12"/>
                                            <DoubleAnimation Storyboard.TargetName="scale" Storyboard.TargetProperty="ScaleY" To="1" Duration="0:0:0.12"/>
                                        </Storyboard></BeginStoryboard>
                                    </EventTrigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- XR체험 버튼 -->
                    <Button x:Name="BtnXrExperience"
                            Height="80" Margin="8,4"
                            Click="BtnXrExperience_Click">
                        <Button.Effect>
                            <DropShadowEffect Color="#AAAAAA" Direction="270" ShadowDepth="0" BlurRadius="14" Opacity="0.45"/>
                        </Button.Effect>
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border CornerRadius="12" ClipToBounds="True">
                                    <Border x:Name="bg" CornerRadius="12">
                                        <Border.RenderTransform><ScaleTransform x:Name="scale" ScaleX="1" ScaleY="1"/></Border.RenderTransform>
                                        <Border.RenderTransformOrigin>0.5,0.5</Border.RenderTransformOrigin>
                                        <Border.Background>
                                            <ImageBrush ImageSource="pack://application:,,,/Images/체험.png" Stretch="UniformToFill"
                                                        RenderOptions.BitmapScalingMode="HighQuality"/>
                                        </Border.Background>
                                    </Border>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="bg" Property="Opacity" Value="0.85"/></Trigger>
                                    <EventTrigger RoutedEvent="Button.PreviewMouseLeftButtonDown">
                                        <BeginStoryboard><Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="scale" Storyboard.TargetProperty="ScaleX" To="0.92" Duration="0:0:0.08"/>
                                            <DoubleAnimation Storyboard.TargetName="scale" Storyboard.TargetProperty="ScaleY" To="0.92" Duration="0:0:0.08"/>
                                        </Storyboard></BeginStoryboard>
                                    </EventTrigger>
                                    <EventTrigger RoutedEvent="Button.PreviewMouseLeftButtonUp">
                                        <BeginStoryboard><Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="scale" Storyboard.TargetProperty="ScaleX" To="1" Duration="0:0:0.12"/>
                                            <DoubleAnimation Storyboard.TargetName="scale" Storyboard.TargetProperty="ScaleY" To="1" Duration="0:0:0.12"/>
                                        </Storyboard></BeginStoryboard>
                                    </EventTrigger>
                                    <EventTrigger RoutedEvent="Button.MouseLeave">
                                        <BeginStoryboard><Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="scale" Storyboard.TargetProperty="ScaleX" To="1" Duration="0:0:0.12"/>
                                            <DoubleAnimation Storyboard.TargetName="scale" Storyboard.TargetProperty="ScaleY" To="1" Duration="0:0:0.12"/>
                                        </Storyboard></BeginStoryboard>
                                    </EventTrigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- XR Coding 버튼 -->
                    <Button x:Name="BtnXrCoding"
                            Height="80" Margin="8,4"
                            Click="BtnXrCoding_Click">
                        <Button.Effect>
                            <DropShadowEffect Color="#AAAAAA" Direction="270" ShadowDepth="0" BlurRadius="14" Opacity="0.45"/>
                        </Button.Effect>
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border CornerRadius="12" ClipToBounds="True">
                                    <Border x:Name="bg" CornerRadius="12">
                                        <Border.RenderTransform><ScaleTransform x:Name="scale" ScaleX="1" ScaleY="1"/></Border.RenderTransform>
                                        <Border.RenderTransformOrigin>0.5,0.5</Border.RenderTransformOrigin>
                                        <Border.Background>
                                            <ImageBrush ImageSource="pack://application:,,,/Images/코딩.png" Stretch="UniformToFill"
                                                        RenderOptions.BitmapScalingMode="HighQuality"/>
                                        </Border.Background>
                                    </Border>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="bg" Property="Opacity" Value="0.85"/></Trigger>
                                    <EventTrigger RoutedEvent="Button.PreviewMouseLeftButtonDown">
                                        <BeginStoryboard><Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="scale" Storyboard.TargetProperty="ScaleX" To="0.92" Duration="0:0:0.08"/>
                                            <DoubleAnimation Storyboard.TargetName="scale" Storyboard.TargetProperty="ScaleY" To="0.92" Duration="0:0:0.08"/>
                                        </Storyboard></BeginStoryboard>
                                    </EventTrigger>
                                    <EventTrigger RoutedEvent="Button.PreviewMouseLeftButtonUp">
                                        <BeginStoryboard><Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="scale" Storyboard.TargetProperty="ScaleX" To="1" Duration="0:0:0.12"/>
                                            <DoubleAnimation Storyboard.TargetName="scale" Storyboard.TargetProperty="ScaleY" To="1" Duration="0:0:0.12"/>
                                        </Storyboard></BeginStoryboard>
                                    </EventTrigger>
                                    <EventTrigger RoutedEvent="Button.MouseLeave">
                                        <BeginStoryboard><Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="scale" Storyboard.TargetProperty="ScaleX" To="1" Duration="0:0:0.12"/>
                                            <DoubleAnimation Storyboard.TargetName="scale" Storyboard.TargetProperty="ScaleY" To="1" Duration="0:0:0.12"/>
                                        </Storyboard></BeginStoryboard>
                                    </EventTrigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- XR English 버튼 -->
                    <Button x:Name="BtnXrEnglish"
                            Height="80" Margin="8,4"
                            Click="BtnXrEnglish_Click">
                        <Button.Effect>
                            <DropShadowEffect Color="#AAAAAA" Direction="270" ShadowDepth="0" BlurRadius="14" Opacity="0.45"/>
                        </Button.Effect>
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border CornerRadius="12" ClipToBounds="True">
                                    <Border x:Name="bg" CornerRadius="12">
                                        <Border.RenderTransform><ScaleTransform x:Name="scale" ScaleX="1" ScaleY="1"/></Border.RenderTransform>
                                        <Border.RenderTransformOrigin>0.5,0.5</Border.RenderTransformOrigin>
                                        <Border.Background>
                                            <ImageBrush ImageSource="pack://application:,,,/Images/alphatong.png" Stretch="UniformToFill"
                                                        RenderOptions.BitmapScalingMode="HighQuality"/>
                                        </Border.Background>
                                    </Border>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="bg" Property="Opacity" Value="0.85"/></Trigger>
                                    <EventTrigger RoutedEvent="Button.PreviewMouseLeftButtonDown">
                                        <BeginStoryboard><Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="scale" Storyboard.TargetProperty="ScaleX" To="0.92" Duration="0:0:0.08"/>
                                            <DoubleAnimation Storyboard.TargetName="scale" Storyboard.TargetProperty="ScaleY" To="0.92" Duration="0:0:0.08"/>
                                        </Storyboard></BeginStoryboard>
                                    </EventTrigger>
                                    <EventTrigger RoutedEvent="Button.PreviewMouseLeftButtonUp">
                                        <BeginStoryboard><Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="scale" Storyboard.TargetProperty="ScaleX" To="1" Duration="0:0:0.12"/>
                                            <DoubleAnimation Storyboard.TargetName="scale" Storyboard.TargetProperty="ScaleY" To="1" Duration="0:0:0.12"/>
                                        </Storyboard></BeginStoryboard>
                                    </EventTrigger>
                                    <EventTrigger RoutedEvent="Button.MouseLeave">
                                        <BeginStoryboard><Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="scale" Storyboard.TargetProperty="ScaleX" To="1" Duration="0:0:0.12"/>
                                            <DoubleAnimation Storyboard.TargetName="scale" Storyboard.TargetProperty="ScaleY" To="1" Duration="0:0:0.12"/>
                                        </Storyboard></BeginStoryboard>
                                    </EventTrigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ====== 오른쪽 콘텐츠 영역 ====== -->
        <Border Grid.Column="1" Background="#E8650A" CornerRadius="16" Margin="0,8,8,8">
            <Border.Effect>
                <DropShadowEffect Color="#AAAAAA" Direction="270" ShadowDepth="0" BlurRadius="24" Opacity="0.35"/>
            </Border.Effect>
            <Grid>

                <!-- ── 패널 1: XR체험프로그램 (앱 아이콘 2×5) ── -->
                <Border x:Name="PanelXrExperience" Visibility="Collapsed"
                        Background="#E8650A" CornerRadius="0" Margin="12">
                    <Border Background="#111827" CornerRadius="20" Margin="4" Padding="16">
                        <UniformGrid Rows="2" Columns="5">
                            <!-- Tag=0: 영어마을 -->
                            <Button Style="{StaticResource AppIconBtn}" Click="AllDeviceStartAppBtn_Click" Tag="0">
                                <Image Source="Images/EnglishTown.png" Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality"/>
                            </Button>
                            <!-- Tag=1: 해양탐험 -->
